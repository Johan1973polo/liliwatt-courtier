<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EcoGies - Extraction Factures Énergie</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .header {
            background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
            color: white;
            padding: 30px;
            text-align: center;
            position: relative;
        }
        
        .logo {
            position: absolute;
            left: 30px;
            top: 50%;
            transform: translateY(-50%);
            width: 120px;
            height: 60px;
            background: white;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: #00CED1;
            font-size: 18px;
        }
        
        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }
        
        .progress-bar {
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 30px 0;
            padding: 0 50px;
            flex-wrap: wrap;
        }
        
        .step {
            display: flex;
            align-items: center;
            color: #94a3b8;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            padding: 10px;
            border-radius: 10px;
        }
        
        .step:hover {
            background: rgba(0, 206, 209, 0.1);
        }
        
        .step.active {
            color: #00CED1;
            font-weight: bold;
        }
        
        .step.completed {
            color: #10b981;
        }
        
        .step-number {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 10px;
            font-weight: bold;
        }
        
        .step.active .step-number {
            background: #00CED1;
            color: white;
        }
        
        .step.completed .step-number {
            background: #10b981;
            color: white;
        }
        
        .step-connector {
            width: 40px;
            height: 2px;
            background: #e2e8f0;
            margin: 0 10px;
        }
        
        .step.completed + .step-connector {
            background: #10b981;
        }
        
        .content {
            padding: 40px;
        }
        
        .step-content {
            display: none;
        }
        
        .step-content.active {
            display: block;
        }
        
        /* Étape 1 - Upload */
        .upload-section {
            background: #f8f9fa;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
        }
        
        .energy-selection {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .energy-option {
            border: 2px solid #e0e0e0;
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .energy-option:hover {
            border-color: #00CED1;
            transform: translateY(-2px);
        }
        
        .energy-option.selected {
            border-color: #00CED1;
            background: #f0f9ff;
        }
        
        .tariff-selection {
            margin: 20px 0;
            display: none;
        }
        
        .tariff-selection.show {
            display: block;
        }
        
        .upload-zone {
            border: 3px dashed #00CED1;
            border-radius: 15px;
            padding: 40px;
            cursor: pointer;
            transition: all 0.3s;
            margin: 15px 0;
            text-align: center;
        }
        
        .upload-zone:hover {
            background: #f0f9ff;
            border-color: #32CD32;
        }
        
        .upload-zone.dragover {
            background: #00CED1;
            color: white;
        }
        
        .dual-upload {
            display: none;
        }
        
        .dual-upload.show {
            display: block;
        }
        
        /* Étape 2 - Données extraites */
        .extracted-data {
            background: #f8f9fa;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
        }
        
        .data-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .data-card {
            background: white;
            border: 2px solid #e0e0e0;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .data-card.missing {
            border-color: #ef4444;
            background: #fef2f2;
        }
        
        .data-card.prix-card {
            border-color: #f59e0b;
            background: #fffbeb;
        }
        
        .data-card h3 {
            color: #1e3a8a;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .data-card.missing h3 {
            color: #ef4444;
        }
        
        .data-card.prix-card h3 {
            color: #f59e0b;
        }
        
        .data-value {
            font-size: 1.1em;
            font-weight: bold;
            color: #2563eb;
            word-break: break-all;
        }
        
        .missing-data {
            color: #ef4444;
            font-style: italic;
        }
        
        .manual-input {
            width: 100%;
            padding: 12px;
            border: 2px solid #d1d5db;
            border-radius: 8px;
            margin-top: 10px;
            font-size: 16px;
        }
        
        .manual-input:focus {
            border-color: #00CED1;
            outline: none;
        }
        
        /* Prix grid spécialisé */
        .prix-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }
        
        .prix-item {
            background: white;
            border: 2px solid #f59e0b;
            border-radius: 10px;
            padding: 15px;
        }
        
        .prix-item.found {
            border-color: #10b981;
            background: #f0fdf4;
        }
        
        .prix-item h4 {
            color: #f59e0b;
            margin-bottom: 10px;
        }
        
        .prix-item.found h4 {
            color: #10b981;
        }
        
        /* Étape 3 - Volumes */
        .volumes-section {
            background: #f8f9fa;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
        }
        
        .volume-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .volume-table th {
            background: #1e3a8a;
            color: white;
            padding: 15px;
            text-align: center;
        }
        
        .volume-table td {
            padding: 15px;
            text-align: center;
            border-bottom: 1px solid #e5e7eb;
        }
        
        .volume-input {
            width: 100%;
            padding: 8px;
            border: 1px solid #d1d5db;
            border-radius: 5px;
            text-align: center;
        }
        
        /* Étape 4 - Prix OHM */
        .prix-section {
            background: #f8f9fa;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
        }
        
        .abonnement-choice {
            background: white;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
            border: 2px solid #e5e7eb;
        }
        
        .abonnement-options {
            display: flex;
            gap: 20px;
            margin-top: 15px;
        }
        
        .abonnement-option {
            flex: 1;
            border: 2px solid #e5e7eb;
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .abonnement-option:hover {
            border-color: #00CED1;
        }
        
        .abonnement-option.selected {
            border-color: #00CED1;
            background: #f0f9ff;
        }
        
        .prix-ohm-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .prix-ohm-table th {
            background: #10b981;
            color: white;
            padding: 12px;
            text-align: center;
        }
        
        .prix-ohm-table td {
            padding: 10px;
            text-align: center;
            border-bottom: 1px solid #e5e7eb;
        }
        
        .prix-ohm-input {
            width: 80px;
            padding: 5px;
            border: 1px solid #d1d5db;
            border-radius: 3px;
            text-align: center;
        }
        
        /* Étape 5 - Comparatif */
        .comparatif-section {
            background: #f8f9fa;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
        }
        
        .economies-banner {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
            text-align: center;
        }
        
        .economies-amount {
            font-size: 3em;
            font-weight: bold;
            margin-bottom: 10px;
        }
        
        .economies-percent {
            font-size: 1.5em;
            opacity: 0.9;
        }
        
        .client-info-card {
            background: white;
            border: 2px solid #3b82f6;
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
        }
        
        .client-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }
        
        .client-info-item {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .client-info-item strong {
            color: #1e3a8a;
        }
        
        /* Étape 6 - MEC */
        .mec-section {
            background: #f8f9fa;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
        }
        
        .fournisseur-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
        }
        
        .fournisseur-card {
            border: 2px solid #e5e7eb;
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: white;
        }
        
        .fournisseur-card:hover {
            border-color: #00CED1;
            transform: translateY(-2px);
        }
        
        .fournisseur-card.selected {
            border-color: #00CED1;
            background: #f0f9ff;
        }
        
        .fournisseur-logo {
            width: 60px;
            height: 30px;
            background: linear-gradient(135deg, #3b82f6, #1e3a8a);
            border-radius: 5px;
            margin: 0 auto 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8em;
            color: white;
            font-weight: bold;
        }
        
        /* Boutons */
        button {
            background: linear-gradient(135deg, #00CED1 0%, #32CD32 100%);
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            border: none;
            padding: 15px 30px;
            border-radius: 10px;
            font-size: 16px;
            margin: 10px 5px;
        }
        
        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,206,209,0.3);
        }
        
        button:disabled {
            background: #9ca3af;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }
        
        .btn-secondary {
            background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        }
        
        .btn-success {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
        }
        
        .btn-outline {
            background: transparent;
            border: 2px solid #00CED1;
            color: #00CED1;
        }
        
        .btn-warning {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        }
        
        .loading {
            display: none;
            text-align: center;
            padding: 40px;
        }
        
        .loading::after {
            content: '⚡';
            display: inline-block;
            animation: spin 1s linear infinite;
            font-size: 2em;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Modal */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
        }
        
        .modal-content {
            background-color: white;
            margin: 2% auto;
            padding: 30px;
            border-radius: 15px;
            width: 90%;
            max-width: 800px;
            max-height: 90vh;
            overflow-y: auto;
        }
        
        .close {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }
        
        .close:hover {
            color: #000;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #374151;
        }
        
        .form-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 16px;
        }
        
        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 15px;
            margin: 20px 0;
            padding: 20px;
            background: #f0f9ff;
            border-radius: 10px;
            border: 2px solid #00CED1;
        }
        
        .checkbox-group input[type="checkbox"] {
            width: 20px;
            height: 20px;
            margin: 0;
        }
        
        .rgpd-text {
            background: #f9f9f9;
            padding: 20px;
            border-radius: 10px;
            font-size: 0.9em;
            line-height: 1.6;
            color: #374151;
            max-height: 300px;
            overflow-y: auto;
            margin: 20px 0;
        }
        
        .validation-banner {
            background: #10b981;
            color: white;
            padding: 15px;
            border-radius: 10px;
            margin: 20px 0;
            text-align: center;
        }
        
        .validation-banner.error {
            background: #ef4444;
        }
        
        .validation-banner.warning {
            background: #f59e0b;
        }
        
        @media (max-width: 768px) {
            .container {
                margin: 10px;
                border-radius: 10px;
            }
            
            .header {
                padding: 20px;
            }
            
            .logo {
                display: none;
            }
            
            .content {
                padding: 20px;
            }
            
            .progress-bar {
                padding: 0 20px;
                overflow-x: auto;
            }
            
            .data-grid, .fournisseur-grid {
                grid-template-columns: 1fr;
            }
            
            .energy-selection {
                grid-template-columns: 1fr;
            }
            
            .step-connector {
                width: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">ECOGIES</div>
            <h1>⚡ EcoGies</h1>
            <p>Extraction et Comparatif Énergétique Professionnel</p>
        </div>
        
        <!-- Barre de progression -->
        <div class="progress-bar">
            <div class="step active" id="step1" onclick="goToStep(1)">
                <div class="step-number">1</div>
                <span>Extraction</span>
            </div>
            <div class="step-connector"></div>
            <div class="step" id="step2" onclick="goToStep(2)">
                <div class="step-number">2</div>
                <span>Données</span>
            </div>
            <div class="step-connector"></div>
            <div class="step" id="step3" onclick="goToStep(3)">
                <div class="step-number">3</div>
                <span>Volumes</span>
            </div>
            <div class="step-connector"></div>
            <div class="step" id="step4" onclick="goToStep(4)">
                <div class="step-number">4</div>
                <span>Prix OHM</span>
            </div>
            <div class="step-connector"></div>
            <div class="step" id="step5" onclick="goToStep(5)">
                <div class="step-number">5</div>
                <span>Comparatif</span>
            </div>
            <div class="step-connector"></div>
            <div class="step" id="step6" onclick="goToStep(6)">
                <div class="step-number">6</div>
                <span>MEC</span>
            </div>
            <div class="step-connector"></div>
            <div class="step" id="step7" onclick="goToStep(7)">
                <div class="step-number">7</div>
                <span>Email</span>
            </div>
        </div>
        
        <div class="content">
            <!-- Étape 1: Upload et Extraction -->
            <div class="step-content active" id="content1">
                <h2 style="color: #1e3a8a; margin-bottom: 30px;">📄 Étape 1 : Extraction des données</h2>
                
                <div class="upload-section">
                    <h3>Sélection du type d'énergie</h3>
                    <div class="energy-selection">
                        <div class="energy-option" onclick="selectEnergy('electricity')">
                            <h4>⚡ Électricité</h4>
                            <p>Factures électricité professionnelle</p>
                        </div>
                        <div class="energy-option" onclick="selectEnergy('gas')">
                            <h4>🔥 Gaz</h4>
                            <p>Factures gaz naturel</p>
                        </div>
                    </div>
                    
                    <div class="tariff-selection" id="electricityTariff">
                        <h4>Type de tarification électricité :</h4>
                        <div style="display: flex; gap: 20px; margin-top: 15px; flex-wrap: wrap;">
                            <label style="display: flex; align-items: center; gap: 10px;">
                                <input type="radio" name="tariff" value="c5" checked>
                                <span>C5 (Tarif simple - 1 facture)</span>
                            </label>
                            <label style="display: flex; align-items: center; gap: 10px;">
                                <input type="radio" name="tariff" value="other">
                                <span>Autre (C4/C2 - 2 factures)</span>
                            </label>
                        </div>
                    </div>
                    
                    <div id="singleUpload">
                        <h4>Facture à analyser</h4>
                        <div class="upload-zone" id="uploadZone1" 
                             ondrop="handleDrop(event, 1)" 
                             ondragover="handleDragOver(event)" 
                             ondragleave="handleDragLeave(event)"
                             onclick="document.getElementById('fileInput1').click()">
                            <div style="font-size: 48px; margin-bottom: 20px;">📎</div>
                            <h4>Glissez votre facture ici</h4>
                            <p>ou cliquez pour sélectionner</p>
                            <p style="font-size: 14px; color: #666; margin-top: 10px;">
                                Formats acceptés: PDF, JPG, PNG
                            </p>
                            <input type="file" id="fileInput1" style="display: none;" 
                                   accept=".pdf,.jpg,.jpeg,.png" onchange="handleFileSelect(event, 1)">
                        </div>
                        <div id="fileName1" style="color: #00CED1; font-weight: bold; margin-top: 10px;"></div>
                    </div>
                    
                    <div class="dual-upload" id="dualUpload">
                        <h4>Facture période 1 (hiver ou été)</h4>
                        <div class="upload-zone" id="uploadZone2" 
                             ondrop="handleDrop(event, 2)" 
                             ondragover="handleDragOver(event)" 
                             ondragleave="handleDragLeave(event)"
                             onclick="document.getElementById('fileInput2').click()">
                            <div style="font-size: 48px; margin-bottom: 20px;">📎</div>
                            <h4>Première facture</h4>
                            <p>Cliquez pour sélectionner</p>
                            <input type="file" id="fileInput2" style="display: none;" 
                                   accept=".pdf,.jpg,.jpeg,.png" onchange="handleFileSelect(event, 2)">
                        </div>
                        <div id="fileName2" style="color: #00CED1; font-weight: bold; margin-top: 10px;"></div>
                        
                        <h4 style="margin-top: 30px;">Facture période 2 (hiver ou été)</h4>
                        <div class="upload-zone" id="uploadZone3" 
                             ondrop="handleDrop(event, 3)" 
                             ondragover="handleDragOver(event)" 
                             ondragleave="handleDragLeave(event)"
                             onclick="document.getElementById('fileInput3').click()">
                            <div style="font-size: 48px; margin-bottom: 20px;">📎</div>
                            <h4>Deuxième facture</h4>
                            <p>Cliquez pour sélectionner</p>
                            <input type="file" id="fileInput3" style="display: none;" 
                                   accept=".pdf,.jpg,.jpeg,.png" onchange="handleFileSelect(event, 3)">
                        </div>
                        <div id="fileName3" style="color: #00CED1; font-weight: bold; margin-top: 10px;"></div>
                    </div>
                    
                    <button onclick="extractData()" style="width: 100%; margin-top: 30px;">
                        🔍 Extraire les données avec GPT-4
                    </button>
                </div>
                
                <div class="loading" id="loading">
                    <h3>Extraction en cours...</h3>
                    <p>L'IA GPT-4 analyse votre facture avec precision maximale</p>
                </div>
            </div>
            
            <!-- Étape 2: Données extraites et validation -->
            <div class="step-content" id="content2">
                <h2 style="color: #1e3a8a; margin-bottom: 30px;">📊 Étape 2 : Données extraites et validation</h2>
                
                <div class="extracted-data">
                    <div id="extractionStatus" class="validation-banner" style="display: none;">
                        <span id="extractionStatusText"></span>
                    </div>
                    
                    <div class="data-grid" id="dataGrid">
                        <!-- Les données extraites seront affichées ici -->
                    </div>
                    
                    <div id="prixSection" style="display: none;">
                        <h3 style="color: #f59e0b; margin: 30px 0 20px 0;">💰 Prix extraits / À compléter</h3>
                        <div class="prix-grid" id="prixGrid">
                            <!-- Les prix seront affichés ici -->
                        </div>
                    </div>
                    
                    <div style="text-align: center; margin-top: 30px;">
                        <button onclick="validateAllData()" class="btn-warning">
                            ✅ Valider toutes les données
                        </button>
                        <button onclick="showRGPDModal()" class="btn-success">
                            📄 Générer RGPD
