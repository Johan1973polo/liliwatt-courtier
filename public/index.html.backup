    <!-- Modal RGPD -->
    <div id="rgpdModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeRGPDModal()">&times;</span>
            <h2 style="color: #1e3a8a; margin-bottom: 20px;">📋 Génération RGPD</h2>
            
            <form id="rgpdForm">
                <div class="form-group">
                    <label>Civilité *</label>
                    <div style="display: flex; gap: 20px; margin-top: 10px;">
                        <label style="display: flex; align-items: center; cursor: pointer;">
                            <input type="radio" name="civilite" value="M." required style="margin-right: 8px;">
                            M.
                        </label>
                        <label style="display: flex; align-items: center; cursor: pointer;">
                            <input type="radio" name="civilite" value="Mme" required style="margin-right: 8px;">
                            Mme
                        </label>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="gerantNom">Nom du gérant *</label>
                    <input type="text" id="gerantNom" required>
                </div>
                
                <div class="form-group">
                    <label for="gerantPrenom">Prénom du gérant *</label>
                    <input type="text" id="gerantPrenom" required>
                </div>
                
                <div class="form-group">
                    <label for="gerantEmail">Email *</label>
                    <input type="email" id="gerantEmail" required>
                </div>
                
                <div class="form-group">
                    <label for="gerantTelephone">Téléphone *</label>
                    <input type="tel" id="gerantTelephone" required>
                </div>
                
                <div class="form-group">
                    <label for="clientSiren">SIREN (si manquant)</label>
                    <input type="text" id="clientSiren" maxlength="9" placeholder="9 chiffres">
                </div>
                
                <div class="rgpd-text">
                    <h4 style="margin-bottom: 15px;">CONSENTEMENT RGPD</h4>
                    <p><strong>En activant l'option ci-dessous, je donne mon accord à ECOGIES pour qu'elle puisse accéder et exploiter les informations techniques issues de mes compteurs, incluant l'historique de ma consommation, et spécifiquement pour recueillir mon adresse email dans le cadre de communications et de relances par email, en respectant les dispositions de la Réglementation Générale sur la Protection des Données (RGPD).</strong></p>
                    
                    <p>Par cette action, je donne mon consentement explicite pour que Ecogies recueille, traite, et utilise les données et informations techniques de mes compteurs à des fins d'analyse de mes habitudes de consommation et pour l'envoi d'emails personnalisés relatifs à leurs services énergétiques. Ces données, y compris mon adresse email, seront conservées le temps nécessaire, conformément aux lois applicables.</p>
                    
                    <p>Je suis conscient(e) que je peux retirer mon consentement concernant l'utilisation de mon adresse email et des autres données à tout moment en adressant une demande écrite à bo@ecogies.fr. La rétraction de mon consentement n'influencera pas la légitimité du traitement effectué avant cette rétraction.</p>
                    
                    <p>En activant cette option, je confirme avoir pris connaissance, compris et accepté les termes de ce consentement conforme au RGPD, incluant la collecte et l'utilisation de mon adresse email pour la relance par mailing.</p>
                </div>
                
                <div class="checkbox-group">
                    <input type="checkbox" id="rgpdConsent" required>
                    <label for="rgpdConsent">
                        <strong>✅ ACCEPTED - CONSENTEMENT RGPD</strong><br>
                        Je confirme avoir lu et accepté les conditions ci-dessus
                    </label>
                </div>
                
                <div style="text-align: center; margin-top: 30px;">
                    <button type="button" onclick="generateRGPDPDF()" class="btn-success">
                        📄 Générer PDF RGPD Complet
                    </button>
                    <button type="button" onclick="closeRGPDModal()" class="btn-outline">
                        Annuler
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    <script>
        // Variables globales
        let selectedFiles = { file1: null, file2: null, file3: null };
        let extractedData = null;
        let currentStep = 1;
        let selectedEnergy = 'electricity';
        let selectedTariff = 'c5';
        let selectedAbonnement = 240;
        let selectedFournisseurs = [];
        let volumeData = {};
        let prixOhmData = {};
        let validationStatus = {
            dataComplete: false,
            prixComplete: false
        };
        let gerantData = null;  // Stockage des données du gérant RGPD
        
        // Fonctions de navigation
        function goToStep(step) {
            // Permettre navigation directe si étape déjà visitée
            if (document.getElementById(`step${step}`).classList.contains('completed') || step <= currentStep) {
                switchToStep(step);
            }
        }
        
        function nextStep(step) {
            document.getElementById(`step${currentStep}`).classList.remove('active');
            document.getElementById(`step${currentStep}`).classList.add('completed');
            switchToStep(step);
        }
        
        function prevStep(step) {
            switchToStep(step);
        }
        
        function switchToStep(step) {
            // Masquer contenu actuel
            document.getElementById(`content${currentStep}`).classList.remove('active');
            document.getElementById(`step${currentStep}`).classList.remove('active');
            
            currentStep = step;
            
            // Afficher nouveau contenu
            document.getElementById(`content${currentStep}`).classList.add('active');
            document.getElementById(`step${currentStep}`).classList.add('active');
            
            // Initialiser l'étape
            if (step === 3) initVolumeStep();
            if (step === 4) initPrixStep();
            if (step === 5) initComparatifStep();
        }
        
        // Sélection d'énergie
        function selectEnergy(type) {
            selectedEnergy = type;
            
            // Mise à jour visuelle
            document.querySelectorAll('.energy-option').forEach(opt => opt.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
            
            // Affichage conditionnel de la sélection tarif
            const electricityTariff = document.getElementById('electricityTariff');
            if (type === 'electricity') {
                electricityTariff.classList.add('show');
            } else {
                electricityTariff.classList.remove('show');
                selectedTariff = 'gas';
            }
            
            updateUploadZones();
        }
        
        // Gestion des tarifs
        document.addEventListener('change', function(e) {
            if (e.target.name === 'tariff') {
                selectedTariff = e.target.value;
                console.log('🔄 Changement de tarif:', selectedTariff);
                
                // Réinitialiser les fichiers lors du changement de tarif
                selectedFiles = {};
                document.getElementById('fileName1').textContent = '';
                document.getElementById('fileName2').textContent = '';
                document.getElementById('fileName3').textContent = '';
                console.log('🗑️ Fichiers réinitialisés');
                
                updateUploadZones();
            }
        });
        
        function updateUploadZones() {
            const singleUpload = document.getElementById('singleUpload');
            const dualUpload = document.getElementById('dualUpload');
            
            console.log('🔄 updateUploadZones appelé');
            console.log('selectedTariff actuel:', selectedTariff);
            
            if (selectedTariff === 'other') {
                console.log('✅ C4/C2 détecté - Affichage dual upload');
                singleUpload.style.display = 'none';
                dualUpload.classList.add('show');
                console.log('dualUpload.classList:', dualUpload.classList.toString());
            } else {
                console.log('📄 Tarif standard - Affichage single upload');
                singleUpload.style.display = 'block';
                dualUpload.classList.remove('show');
            }
        }
        
        // Gestion des fichiers
        function handleFileSelect(event, fileNum) {
            const file = event.target.files[0];
            console.log(`📁 handleFileSelect appelé pour file${fileNum}`);
            console.log('Fichier sélectionné:', file ? file.name : 'Aucun');
            
            if (file) {
                selectedFiles[`file${fileNum}`] = file;
                document.getElementById(`fileName${fileNum}`).textContent = '📄 ' + file.name;
                console.log(`✅ file${fileNum} stocké dans selectedFiles`);
                console.log('État selectedFiles après ajout:', selectedFiles);
            }
        }
        
        function handleDrop(event, fileNum) {
            event.preventDefault();
            event.stopPropagation();
            event.currentTarget.classList.remove('dragover');
            
            const file = event.dataTransfer.files[0];
            console.log(`📁 handleDrop appelé pour file${fileNum}`);
            console.log('Fichier déposé:', file ? file.name : 'Aucun');
            
            if (file) {
                selectedFiles[`file${fileNum}`] = file;
                document.getElementById(`fileName${fileNum}`).textContent = '📄 ' + file.name;
                console.log(`✅ file${fileNum} stocké dans selectedFiles (via drop)`);
                console.log('État selectedFiles après drop:', selectedFiles);
            }
        }
        
        function handleDragOver(event) {
            event.preventDefault();
            event.stopPropagation();
            event.currentTarget.classList.add('dragover');
        }
        
        function handleDragLeave(event) {
            event.preventDefault();
            event.stopPropagation();
            event.currentTarget.classList.remove('dragover');
        }
        
        // Extraction des données VRAIE API GPT-4
        async function extractData() {
            // DEBUG C4 UPLOAD
            console.log('🔍 DEBUG C4 - État des variables:');
            console.log('selectedTariff:', selectedTariff);
            console.log('selectedFiles:', selectedFiles);
            console.log('file1 exists:', !!selectedFiles.file1);
            console.log('file2 exists:', !!selectedFiles.file2);
            console.log('file3 exists:', !!selectedFiles.file3);
            
            // Validation selon le type de tarif
            if (selectedTariff === 'other') {
                // Pour C4/C2, on a besoin de file2 et file3 (dual upload)
                console.log('🔍 Validation C4/C2 - Vérification file2 et file3');
                if (!selectedFiles.file2 || !selectedFiles.file3) {
                    console.log('❌ ERREUR C4: Fichiers manquants');
                    console.log('file2:', !!selectedFiles.file2, 'file3:', !!selectedFiles.file3);
                    alert('Pour les tarifs C4/C2, vous devez fournir 2 factures (une période été et une période hiver) pour capturer tous les prix saisonniers');
                    return;
                }
            } else {
                // Pour les tarifs normaux, on a besoin de file1 (single upload)
                console.log('🔍 Validation tarif standard - Vérification file1');
                if (!selectedFiles.file1) {
                    console.log('❌ ERREUR: Pas de file1 pour tarif standard');
                    alert('Veuillez sélectionner au moins une facture');
                    return;
                }
            }
            
            document.getElementById('loading').style.display = 'block';
            
            try {
                const formData = new FormData();
                
                // Envoi des fichiers selon le type de tarif
                if (selectedTariff === 'other') {
                    // Pour C4/C2, envoyer file2 et file3
                    console.log('📤 Envoi fichiers C4/C2: file2 et file3');
                    formData.append('file', selectedFiles.file2);
                    formData.append('file2', selectedFiles.file3);
                } else {
                    // Pour tarifs standards, envoyer file1
                    console.log('📤 Envoi fichier standard: file1');
                    formData.append('file', selectedFiles.file1);
                    if (selectedFiles.file2) {
                        formData.append('file2', selectedFiles.file2);
                    }
                }
                
                formData.append('energyType', selectedEnergy);
                formData.append('profileType', selectedTariff);
                
                console.log('🚀 Envoi vers API GPT-4...');
                
                const response = await fetch('/api/upload-and-extract', {
                    method: 'POST',
                    body: formData
                });
                
                console.log('📡 Réponse API reçue:', response.status);
                
                const result = await response.json();
                
                if (result.success) {
                    extractedData = result.data;
                    
                    // Nettoyer les prix mal formatés par GPT-4 (virgules françaises)
                    // Ex: "191,01000" → 191.01 ou "19 110" → 19110
                    function cleanExtractedPrice(value, fieldKey) {
                        if (value === null || value === undefined) return value;
                        
                        // Convertir en string pour traitement
                        let str = value.toString();
                        
                        // Supprimer les espaces (ex: "19 110" → "19110")
                        str = str.replace(/\s/g, '');
                        
                        // Gérer les virgules françaises
                        // Si format "191,01000" → "191.01"
                        if (str.includes(',')) {
                            // Garder seulement 2 décimales après la virgule
                            const parts = str.split(',');
                            if (parts[1] && parts[1].length > 2) {
                                str = parts[0] + '.' + parts[1].substring(0, 2);
                            } else {
                                str = str.replace(',', '.');
                            }
                        }
                        
                        let cleaned = parseFloat(str);
                        
                        // CORRECTION SPÉCIFIQUE PRIMEO : GPT-4 supprime la virgule
                        // Si Primeo et prix > 1000, c'est probablement une erreur d'extraction
                        const fournisseur = extractedData.fournisseur || '';
                        if ((fournisseur.toLowerCase().includes('primeo') || 
                             fournisseur.toLowerCase().includes('priméo')) && 
                            fieldKey && fieldKey.includes('_centimes') && 
                            cleaned > 1000) {
                            
                            const corrected = cleaned / 100;
                            
                            // Si la correction donne un prix dans la plage normale (150-350 €/MWh)
                            if (corrected >= 150 && corrected <= 350) {
                                // Appliquer la correction automatiquement sans demander
                                cleaned = corrected;
                            }
                        }
                        
                        return cleaned;
                    }
                    
                    // Nettoyer et appliquer les conversions intelligentes pour les prix électriques
                    const prixElectriques = ['prix_base_centimes', 'prix_hp_centimes', 'prix_hc_centimes', 
                                            'prix_hpe_centimes', 'prix_hce_centimes', 'prix_hph_centimes', 
                                            'prix_hch_centimes', 'prix_pointe_centimes'];
                    
                    prixElectriques.forEach(key => {
                        if (extractedData[key] !== null && extractedData[key] !== undefined) {
                            const valeurOriginale = extractedData[key];
                            const valeurNettoyee = cleanExtractedPrice(valeurOriginale, key);
                            const valeurConvertie = updateExtractedDataWithConversion(key, valeurNettoyee);
                            extractedData[key] = valeurConvertie;
                        }
                    });
                    
                    // Conversion automatique des abonnements
                    if (extractedData.prix_abonnement_eur) {
                        extractedData.prix_abonnement_eur = convertAbonnementToAnnual(extractedData.prix_abonnement_eur);
                    }
                    
                    // Conversion automatique du prix molécule GAZ si nécessaire
                    if (extractedData.prix_molecule_eur_mwh) {
                        const valeurOriginale = extractedData.prix_molecule_eur_mwh;
                        const valeurConvertie = updateExtractedDataWithConversion('prix_molecule_eur_mwh', valeurOriginale);
                        extractedData.prix_molecule_eur_mwh = valeurConvertie;
                    }
                    
                    
                    document.getElementById('loading').style.display = 'none';
                    displayExtractedData();
                    nextStep(2);
                } else {
                    console.error('❌ Erreur API:', result.error);
                    alert('Erreur lors de l\'extraction: ' + result.error);
                    document.getElementById('loading').style.display = 'none';
                }
                
            } catch (error) {
                console.error('💥 Erreur connexion:', error);
                alert('Erreur de connexion à l\'API: ' + error.message);
                document.getElementById('loading').style.display = 'none';
                
                // FALLBACK: En cas d'erreur, données de test pour développement
                console.log('🔄 Utilisation données de test pour développement...');
                
                if (selectedEnergy === 'gas') {
                    extractedData = {
                        nom_client: 'SARL HOTEL SAINTE SUZANNE',
                        siren: '344721493',
                        pdl_pce: '16537481818869',
                        segment: 'GAZ',
                        fournisseur: 'GazelEnergie',
                        type_offre: 'Prix Fixe',
                        puissance_souscrite: 25,
                        date_fin_contrat: '01/01/2027',
                        adresse_facturation: '18 rue Carnot 22100 DINAN',
                        adresse_consommation: '18 rue Carnot 22100 DINAN',
                        prix_molecule_eur_mwh: 158.16,
                        prix_abonnement_eur: 2420.88,  // 201.74 * 12 (annuel)
                        iban: 'FR7617807000060062145493885'
                    };
                } else if (selectedTariff === 'other') {
                    // C4 avec prix PARTIELS pour test de la complétion manuelle
                    extractedData = {
                        nom_client: 'DINAN PRESSING LAVERIE',
                        siren: '802360099',
                        pdl_pce: '50057417480168',
                        segment: 'C4',
                        fournisseur: 'EDF',
                        type_offre: 'Tarif Pro C4',
                        puissance_souscrite: 84,
                        date_fin_contrat: '15/06/2025',
                        adresse_facturation: '18b rue Carnot 22100 DINAN',
                        adresse_consommation: '18b rue Carnot 22100 DINAN',
                        prix_hpe_centimes: 15.39,
                        prix_hce_centimes: 9.38,
                        prix_hph_centimes: 22.82,
                        prix_hch_centimes: 16.99,
                        prix_abonnement_eur: 3168,  // 264 * 12 (annuel)
                        iban: 'FR7617807000060062145493885'
                    };
                } else {
                    // C5-HPHC avec prix COMPLETS
                    extractedData = {
                        nom_client: 'DINAN PRESSING LAVERIE',
                        siren: '802360099',
                        pdl_pce: '50057417480168',
                        segment: 'C5-HPHC',
                        fournisseur: 'EDF',
                        type_offre: 'Tarif Bleu Pro HP/HC',
                        puissance_souscrite: 84,
                        date_fin_contrat: '15/06/2025',
                        adresse_facturation: '18b rue Carnot 22100 DINAN',
                        adresse_consommation: '18b rue Carnot 22100 DINAN',
                        prix_hp_centimes: 19.11,
                        prix_hc_centimes: 15.48,
                        prix_abonnement_eur: 3168,  // 264 * 12 (annuel)
                        iban: 'FR7617807000060062145493885'
                    };
                }
                
                displayExtractedData();
                nextStep(2);
            }
        }
        
        function displayExtractedData() {
            const dataGrid = document.getElementById('dataGrid');
            const prixSection = document.getElementById('prixSection');
            const prixGrid = document.getElementById('prixGrid');
            const statusDiv = document.getElementById('extractionStatus');
            const statusText = document.getElementById('extractionStatusText');
            
            dataGrid.innerHTML = '';
            prixGrid.innerHTML = '';
            
            // Données principales
            const mainFields = [
                { key: 'nom_client', label: 'Nom Client', icon: '🏢' },
                { key: 'siren', label: 'SIREN', icon: '📊' },
                { key: 'pdl_pce', label: selectedEnergy === 'gas' ? 'PCE' : 'PDL', icon: '📍' },
                { key: 'segment', label: 'Segment', icon: '⚡' },
                { key: 'fournisseur', label: 'Fournisseur', icon: '🏭' },
                { key: 'type_offre', label: 'Type offre', icon: '📄' },
                { key: 'date_fin_contrat', label: 'Fin contrat', icon: '📅' },
                // Afficher Puissance pour électricité ou CAR pour GAZ
                ...(selectedEnergy === 'gas' ? 
                    [{ key: 'car', label: 'CAR (Consommation Annuelle)', icon: '📊', suffix: ' MWh/an' }] : 
                    [{ key: 'puissance_souscrite', label: 'Puissance', icon: '⚡', suffix: ' kVA' }]
                ),
                { key: 'adresse_facturation', label: 'Adresse facturation', icon: '📮' },
                { key: 'adresse_consommation', label: 'Adresse consommation', icon: '📍' },
                { key: 'iban', label: 'IBAN', icon: '💳' }
            ];
            
            let missingCount = 0;
            
            mainFields.forEach(field => {
                const value = extractedData[field.key];
                const card = document.createElement('div');
                card.className = 'data-card';
                
                if (!value || value === 'N/A') {
                    card.classList.add('missing');
                    missingCount++;
                }
                
                // Gestion spéciale pour le champ segment
                if (field.key === 'segment') {
                    card.innerHTML = `
                        <h3>${field.icon} ${field.label}</h3>
                        <div class="data-value ${!value || value === 'N/A' ? 'missing-data' : ''}" id="value-${field.key}">
                            ${value && value !== 'N/A' ? value + (field.suffix || '') : 'Données manquantes'}
                            ${value && value !== 'N/A' ? 
                                `<button onclick="editSegmentField()" style="margin-left: 10px; padding: 2px 8px; background: #3b82f6; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">✏️ Modifier</button>` : 
                                ''
                            }
                        </div>
                        ${!value || value === 'N/A' ? 
                            `<select class="manual-input" id="input-${field.key}" onchange="updateExtractedData('${field.key}', this.value)">
                                <option value="">Sélectionner un segment</option>
                                <option value="C5-BASE">C5-BASE</option>
                                <option value="C5-HPHC">C5-HPHC</option>
                                <option value="C4">C4</option>
                                <option value="C2">C2</option>
                                <option value="GAZ">GAZ</option>
                            </select>` : 
                            `<select class="manual-input" id="input-${field.key}" style="display: none;" onchange="updateExtractedData('${field.key}', this.value)">
                                <option value="">Sélectionner un segment</option>
                                <option value="C5-BASE">C5-BASE</option>
                                <option value="C5-HPHC">C5-HPHC</option>
                                <option value="C4">C4</option>
                                <option value="C2">C2</option>
                                <option value="GAZ">GAZ</option>
                            </select>`
                        }
                    `;
                } else {
                    card.innerHTML = `
                        <h3>${field.icon} ${field.label}</h3>
                        <div class="data-value ${!value || value === 'N/A' ? 'missing-data' : ''}" id="value-${field.key}">
                            ${value && value !== 'N/A' ? value + (field.suffix || '') : 'Données manquantes'}
                            ${value && value !== 'N/A' ? 
                                `<button onclick="editField('${field.key}', '${field.suffix || ''}')" style="margin-left: 10px; padding: 2px 8px; background: #3b82f6; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">✏️ Modifier</button>` : 
                                ''
                            }
                        </div>
                        ${!value || value === 'N/A' ? 
                            `<input type="text" class="manual-input" id="input-${field.key}" placeholder="Saisir manuellement" onchange="updateExtractedData('${field.key}', this.value)">` : 
                            `<input type="text" class="manual-input" id="input-${field.key}" style="display: none;" placeholder="Modifier la valeur" onchange="updateExtractedData('${field.key}', this.value)">`
                        }
                    `;
                }
                
                dataGrid.appendChild(card);
            });
            
            // Affichage des prix selon le segment - TOUJOURS afficher la section
            let prixFields = [];
            let prixMissing = 0;
            
            // Détection automatique C5-BASE vs C5-HPHC si segment pas encore défini
            if (extractedData.segment === 'C5' || !extractedData.segment) {
                // Si on a des prix HP/HC, c'est du C5-HPHC
                if (extractedData.prix_hp_centimes || extractedData.prix_hc_centimes) {
                    extractedData.segment = 'C5-HPHC';
                } else {
                    extractedData.segment = 'C5-BASE';
                }
            }
            
            if (extractedData.segment === 'GAZ') {
                prixFields = [
                    { key: 'prix_molecule_eur_mwh', label: 'Prix molécule', unit: '€/MWh' },
                    { key: 'prix_abonnement_eur', label: 'Abonnement', unit: '€/an' },
                    { key: 'car', label: 'CAR (Consommation Annuelle)', unit: 'MWh/an' }
                ];
            } else if (extractedData.segment === 'C5-BASE') {
                prixFields = [
                    { key: 'prix_base_centimes', label: 'Prix BASE', unit: '€/MWh', isElec: true },
                    { key: 'prix_abonnement_eur', label: 'Abonnement', unit: '€/an' }
                ];
            } else if (extractedData.segment === 'C5-HPHC') {
                prixFields = [
                    { key: 'prix_hp_centimes', label: 'Prix HP', unit: '€/MWh', isElec: true },
                    { key: 'prix_hc_centimes', label: 'Prix HC', unit: '€/MWh', isElec: true },
                    { key: 'prix_abonnement_eur', label: 'Abonnement', unit: '€/an' }
                ];
            } else if (extractedData.segment === 'C4') {
                prixFields = [
                    { key: 'prix_hpe_centimes', label: 'Prix HPE', unit: '€/MWh', isElec: true },
                    { key: 'prix_hce_centimes', label: 'Prix HCE', unit: '€/MWh', isElec: true },
                    { key: 'prix_hph_centimes', label: 'Prix HPH', unit: '€/MWh', isElec: true },
                    { key: 'prix_hch_centimes', label: 'Prix HCH', unit: '€/MWh', isElec: true },
                    { key: 'prix_abonnement_eur', label: 'Abonnement', unit: '€/an' }
                ];
            } else if (extractedData.segment === 'C2') {
                prixFields = [
                    { key: 'prix_hpe_centimes', label: 'Prix HPE', unit: '€/MWh', isElec: true },
                    { key: 'prix_hce_centimes', label: 'Prix HCE', unit: '€/MWh', isElec: true },
                    { key: 'prix_hph_centimes', label: 'Prix HPH', unit: '€/MWh', isElec: true },
                    { key: 'prix_hch_centimes', label: 'Prix HCH', unit: '€/MWh', isElec: true },
                    { key: 'prix_pointe_centimes', label: 'Prix POINTE', unit: '€/MWh', isElec: true },
                    { key: 'prix_abonnement_eur', label: 'Abonnement', unit: '€/an' }
                ];
            } else {
                // Fallback par défaut pour tout autre segment
                prixFields = [
                    { key: 'prix_base_centimes', label: 'Prix', unit: '€/MWh', isElec: true },
                    { key: 'prix_abonnement_eur', label: 'Abonnement', unit: '€/an' }
                ];
            }
            
            // TOUJOURS afficher la section prix
            prixSection.style.display = 'block';
            
            prixFields.forEach(field => {
                let value = extractedData[field.key];
                let displayValue = value;
                
                console.log(`📊 DEBUT affichage prix ${field.key}`);
                console.log(`  → Valeur stockée dans extractedData: ${value}`);
                
                // UTILISER LA NOUVELLE FONCTION QUI RETOURNE DIRECTEMENT LA VALEUR
                if (field.isElec && value !== null && value !== undefined) {
                    // Conversion directe vers €/MWh
                    displayValue = getConvertedPriceToMWh(value, extractedData.fournisseur, field.key);
                    
                    console.log(`  → Après getConvertedPriceToMWh: ${displayValue} €/MWh`);
                    
                    // Pour le badge, on utilise encore detectPriceUnit pour l'info
                    const conversionInfo = detectPriceUnit(value, extractedData.fournisseur, field.key);
                    if (!window.conversionHistory) window.conversionHistory = {};
                    window.conversionHistory[field.key] = conversionInfo;
                    
                } else if (field.key === 'prix_molecule_eur_mwh' && value !== null && value !== undefined) {
                    // Pour le gaz, même logique
                    displayValue = getConvertedPriceToMWh(value, extractedData.fournisseur, field.key);
                    
                    console.log(`🔥 Affichage GAZ: ${value} → ${displayValue} €/MWh`);
                    
                    const conversionInfo = detectPriceUnit(value, extractedData.fournisseur, field.key);
                    if (!window.conversionHistory) window.conversionHistory = {};
                    window.conversionHistory[field.key] = conversionInfo;
                }
                
                const item = document.createElement('div');
                item.className = 'prix-item';
                
                if (value !== null && value !== undefined) {
                    item.classList.add('found');
                } else {
                    prixMissing++;
                }
                
                // Récupérer l'info de conversion si disponible
                const conversionInfo = window.conversionHistory && window.conversionHistory[field.key];
                const conversionBadge = conversionInfo ? 
                    `<span style="font-size: 10px; background: #e0f2fe; color: #0369a1; padding: 2px 6px; border-radius: 4px; margin-left: 5px;" title="${conversionInfo.reason}">
                        ${conversionInfo.unit} → €/MWh
                    </span>` : '';
                
                console.log(`  → Valeur finale à afficher: ${displayValue ? displayValue.toFixed(2) : '0.00'} ${field.unit}`);
                
                item.innerHTML = `
                    <h4>${field.label}${conversionBadge}</h4>
                    ${value !== null && value !== undefined ? 
                        `<div class="data-value" id="value-${field.key}">
                            ${displayValue ? displayValue.toFixed(2) : '0.00'} ${field.unit}
                            <button onclick="editField('${field.key}', ' ${field.unit}')" style="margin-left: 10px; padding: 2px 8px; background: #3b82f6; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">✏️ Modifier</button>
                        </div>
                        <input type="number" class="manual-input" id="input-${field.key}" style="display: none;" placeholder="Modifier ${field.unit}" 
                               step="0.01" data-is-elec="${field.isElec || false}" onchange="updateExtractedData('${field.key}', this.value)">` :
                        `<div class="missing-data">Prix manquant</div>
                         <input type="number" class="manual-input" id="input-${field.key}" placeholder="Saisir ${field.unit}" 
                                step="0.01" data-is-elec="${field.isElec || false}" onchange="updateExtractedData('${field.key}', this.value)">`
                    }
                `;
                
                prixGrid.appendChild(item);
            });
            
            // Affichage du statut
            statusDiv.style.display = 'block';
            if (missingCount === 0 && prixMissing === 0) {
                statusDiv.className = 'validation-banner';
                statusText.textContent = '✅ Extraction complète ! Toutes les données ont été trouvées.';
                validationStatus.dataComplete = true;
                validationStatus.prixComplete = true;
                document.getElementById('nextToVolumes').disabled = false;
            } else if (prixMissing > 0) {
                statusDiv.className = 'validation-banner error';
                statusText.textContent = `⚠️ ${prixMissing} prix manquant(s) - Saisie obligatoire pour continuer`;
                validationStatus.prixComplete = false;
                document.getElementById('nextToVolumes').disabled = true;
            } else {
                statusDiv.className = 'validation-banner warning';
                statusText.textContent = `⚠️ ${missingCount} donnée(s) manquante(s) - Complétion recommandée`;
                validationStatus.dataComplete = false;
                document.getElementById('nextToVolumes').disabled = false;
            }
        }
        
        // Nouvelle fonction qui retourne directement la valeur convertie en €/MWh
        function getConvertedPriceToMWh(value, fournisseur, fieldKey) {
            let price = parseFloat(value);
            
            console.log(`💰 Conversion vers €/MWh pour ${fieldKey}: ${value} (fournisseur: ${fournisseur})`);
            
            // Pour les prix électriques
            if (fieldKey && fieldKey.includes('_centimes')) {
                // PRIMEO ENERGIE : Prix en €/MWh MAIS stockés en c€/kWh après nettoyage
                // Le cleanExtractedPrice a déjà divisé par 100 si > 1000
                // Donc ici on n'a pas besoin de conversion supplémentaire
                if (fournisseur && (fournisseur.toLowerCase().includes('primeo') || 
                                   fournisseur.toLowerCase().includes('priméo'))) {
                    // Primeo est déjà en €/MWh, pas de conversion
                    return price;
                }
                
                // EDF : Prix toujours en c€/kWh
                if (fournisseur && fournisseur.toUpperCase().includes('EDF')) {
                    console.log('→ EDF détecté: c€/kWh × 10');
                    return price * 10; // c€/kWh → €/MWh
                }
                
                // AUTRES FOURNISSEURS : Détection par ordre de grandeur
                if (price < 1) {
                    console.log('→ Valeur < 1: €/kWh × 1000');
                    return price * 1000; // €/kWh → €/MWh
                } else if (price >= 1 && price < 100) {
                    console.log('→ Valeur 1-100: c€/kWh × 10');
                    return price * 10; // c€/kWh → €/MWh
                } else if (price >= 100 && price < 600) {
                    console.log('→ Valeur 100-600: déjà en €/MWh');
                    return price; // Déjà en €/MWh (plage normale 150-400)
                } else if (price >= 600 && price < 50000) {
                    // Probable erreur d'extraction GPT-4 (virgule manquante)
                    const corrected = price / 100;
                    console.warn(`⚠️ Prix aberrant détecté: ${price}`);
                    if (corrected >= 150 && corrected <= 400) {
                        console.log(`→ Correction automatique suggérée: ${corrected} €/MWh`);
                        if (confirm(`Prix détecté: ${price} €/MWh semble aberrant.\nCorrection suggérée: ${corrected} €/MWh\n\nAppliquer la correction ?`)) {
                            return corrected;
                        }
                    }
                    return price;
                } else {
                    console.error('→ Valeur > 50000: très aberrante');
                    alert(`⚠️ Prix très aberrant détecté: ${price}\nVeuillez vérifier manuellement.`);
                    return price;
                }
            }
            
            // Pour le gaz
            if (fieldKey === 'prix_molecule_eur_mwh') {
                if (price < 10) {
                    console.log('→ Gaz < 10: c€/kWh × 10');
                    return price * 10; // c€/kWh → €/MWh
                } else {
                    console.log('→ Gaz >= 10: déjà en €/MWh');
                    return price; // Déjà en €/MWh
                }
            }
            
            // Par défaut, pas de conversion
            return price;
        }
        
        function detectPriceUnit(value, fournisseur, fieldKey) {
            // Détection intelligente de l'unité du prix
            const price = parseFloat(value);
            
            // DEBUG: Log tous les appels
            console.log('🔍 detectPriceUnit appelé:', {
                value: value,
                fournisseur: fournisseur,
                fieldKey: fieldKey,
                price: price
            });
            
            // Pour PRIMEO, les prix sont déjà en €/MWh
            if (fournisseur && (fournisseur.toLowerCase().includes('primeo') || 
                               fournisseur.toLowerCase().includes('priméo'))) {
                const result = { unit: '€/MWh', factor: 1, reason: 'Fournisseur Primeo (€/MWh)' };
                console.log('✅ PRIMEO détecté, retour:', result);
                return result;
            }
            
            // Pour EDF, on sait que c'est toujours en c€/kWh
            if (fournisseur && fournisseur.toUpperCase().includes('EDF')) {
                const result = { unit: 'c€/kWh', factor: 10, reason: 'Fournisseur EDF (c€/kWh)' };
                console.log('✅ EDF détecté, retour:', result);
                return result;
            }
            
            // Détection par ordre de grandeur pour l'électricité
            if (fieldKey.includes('_centimes')) {
                let result;
                if (price < 1) {
                    // Ex: 0.1911 → probablement €/kWh
                    result = { unit: '€/kWh', factor: 1000, reason: 'Valeur < 1 → €/kWh' };
                } else if (price >= 1 && price < 100) {
                    // Ex: 19.11 → probablement c€/kWh (cas le plus courant)
                    result = { unit: 'c€/kWh', factor: 10, reason: 'Valeur 1-100 → c€/kWh' };
                } else if (price >= 100 && price < 500) {
                    // Ex: 191.10 → probablement déjà en €/MWh
                    result = { unit: '€/MWh', factor: 1, reason: 'Valeur 100-500 → €/MWh' };
                } else {
                    // Valeur aberrante
                    result = { unit: 'aberrant', factor: 1, reason: 'Valeur > 500 semble aberrante' };
                }
                console.log('⚡ Électricité détecté, retour:', result);
                return result;
            }
            
            // Pour le gaz (prix molécule)
            if (fieldKey === 'prix_molecule_eur_mwh') {
                if (price < 10) {
                    // Ex: 3.5 → probablement c€/kWh
                    return { unit: 'c€/kWh', factor: 10, reason: 'Prix gaz < 10 → c€/kWh' };
                } else if (price >= 10 && price < 200) {
                    // Ex: 35 → probablement déjà en €/MWh
                    return { unit: '€/MWh', factor: 1, reason: 'Prix gaz 10-200 → €/MWh' };
                } else {
                    return { unit: 'aberrant', factor: 1, reason: 'Prix gaz > 200 semble aberrant' };
                }
            }
            
            return { unit: 'unknown', factor: 1, reason: 'Unité non détectée' };
        }
        
        function updateExtractedDataWithConversion(key, value) {
            console.log(`🔄 DEBUT updateExtractedDataWithConversion pour ${key}`);
            console.log(`  → Valeur entrée: ${value} (type: ${typeof value})`);
            
            // Conversion des unités selon le champ
            let convertedValue = parseFloat(value);
            console.log(`  → Après parseFloat: ${convertedValue}`);
            let conversionInfo = null;
            
            // Détection si la saisie vient de l'interface (input avec data-is-elec)
            const input = document.getElementById(`input-${key}`);
            const isElecInput = input && input.dataset.isElec === 'true';
            
            if (key.includes('_centimes')) {
                if (isElecInput) {
                    // L'utilisateur saisit en €/MWh dans l'interface
                    // On convertit €/MWh → c€/kWh (÷10) pour stockage
                    convertedValue = convertedValue / 10;
                    console.log(`Saisie utilisateur ${key}: ${value} €/MWh → ${convertedValue} c€/kWh (stockage)`);
                } else {
                    // Détection intelligente basée sur le fournisseur et l'ordre de grandeur
                    conversionInfo = detectPriceUnit(value, extractedData.fournisseur, key);
                    
                    if (conversionInfo.unit === 'aberrant') {
                        // Alerter l'utilisateur
                        console.warn(`⚠️ Prix aberrant détecté pour ${key}: ${value}`);
                        alert(`⚠️ Attention : Le prix ${value} semble aberrant (${conversionInfo.reason}). Veuillez vérifier.`);
                    }
                    
                    // Convertir en c€/kWh pour stockage interne
                    if (conversionInfo.unit === '€/kWh') {
                        convertedValue = convertedValue * 100; // €/kWh → c€/kWh
                    } else if (conversionInfo.unit === '€/MWh') {
                        convertedValue = convertedValue / 10; // €/MWh → c€/kWh
                    }
                    // Si c€/kWh, pas de conversion nécessaire
                    
                    console.log(`Détection ${key}: ${value} ${conversionInfo.unit} → ${convertedValue} c€/kWh (${conversionInfo.reason})`);
                    
                    // Stocker l'info de conversion pour affichage
                    if (!window.conversionHistory) window.conversionHistory = {};
                    window.conversionHistory[key] = conversionInfo;
                }
            }
            
            // Prix molécule GAZ - conversion intelligente
            if (key === 'prix_molecule_eur_mwh') {
                conversionInfo = detectPriceUnit(value, extractedData.fournisseur, key);
                
                if (conversionInfo.unit === 'aberrant') {
                    console.warn(`⚠️ Prix gaz aberrant: ${value}`);
                    alert(`⚠️ Attention : Le prix gaz ${value} semble aberrant. Veuillez vérifier.`);
                }
                
                // Convertir en €/MWh pour stockage
                if (conversionInfo.unit === 'c€/kWh') {
                    convertedValue = convertedValue * 10; // c€/kWh → €/MWh
                }
                
                console.log(`Prix GAZ: ${value} ${conversionInfo.unit} → ${convertedValue} €/MWh (${conversionInfo.reason})`);
                
                // Stocker l'info de conversion
                if (!window.conversionHistory) window.conversionHistory = {};
                window.conversionHistory[key] = conversionInfo;
            }
            
            // Conversion €/mois → €/an pour les abonnements
            if (key === 'prix_abonnement_eur') {
                convertedValue = convertAbonnementToAnnual(convertedValue);
            }
            
            console.log(`🔄 FIN updateExtractedDataWithConversion pour ${key}`);
            console.log(`  → Valeur finale retournée: ${convertedValue}`);
            return convertedValue;
        }
        
        function convertAbonnementToAnnual(value) {
            const numValue = parseFloat(value);
            
            // Détection intelligente de la période de facturation
            // Si < 100€ : probablement mensuel → ×12
            // Si 100-500€ : probablement bimestriel (2 mois) → ×6
            // Si > 5000€ : probablement déjà annuel
            
            if (numValue < 100) {
                // Abonnement mensuel
                console.log(`Abonnement détecté comme MENSUEL: ${value}€ → ${numValue * 12}€/an`);
                return numValue * 12;
            } else if (numValue >= 100 && numValue < 500) {
                // Abonnement bimestriel (2 mois)
                console.log(`Abonnement détecté comme BIMESTRIEL: ${value}€ → ${numValue * 6}€/an`);
                return numValue * 6;
            } else if (numValue >= 500 && numValue < 5000) {
                // Pourrait être trimestriel ou semestriel, on suppose mensuel par défaut
                console.log(`Abonnement ambigu, supposé MENSUEL: ${value}€ → ${numValue * 12}€/an`);
                return numValue * 12;
            } else {
                // Déjà annuel
                console.log(`Abonnement déjà ANNUEL: ${value}€/an`);
                return numValue;
            }
        }
        
        function editSegmentField() {
            // Masquer la valeur actuelle et afficher le select
            const valueDiv = document.getElementById('value-segment');
            const select = document.getElementById('input-segment');
            
            if (valueDiv && select) {
                valueDiv.style.display = 'none';
                select.style.display = 'block';
                
                // Pré-sélectionner la valeur actuelle
                select.value = extractedData.segment || '';
                
                // Focus sur le select
                select.focus();
                
                // Ajouter un listener pour fermer sur Escape
                select.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape') {
                        cancelEdit('segment');
                    }
                });
            }
        }
        
        function editField(key, suffix) {
            // Masquer la valeur actuelle et afficher l'input
            const valueDiv = document.getElementById(`value-${key}`);
            const input = document.getElementById(`input-${key}`);
            
            if (valueDiv && input) {
                valueDiv.style.display = 'none';
                input.style.display = 'block';
                
                // Pré-remplir avec la valeur actuelle
                const currentValue = extractedData[key];
                const isElecInput = input.dataset.isElec === 'true';
                
                if (currentValue && currentValue !== 'N/A') {
                    // Si c'est un prix électrique, afficher en €/MWh (×10)
                    if (isElecInput && key.includes('_centimes')) {
                        input.value = (currentValue * 10).toFixed(2);  // Afficher en €/MWh
                    } else {
                        input.value = currentValue;
                    }
                }
                
                // Focus sur l'input
                input.focus();
                
                // Ajouter un listener pour fermer sur Escape
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape') {
                        cancelEdit(key);
                    } else if (e.key === 'Enter') {
                        updateExtractedData(key, input.value);
                    }
                }, { once: true });
            }
        }
        
        function cancelEdit(key) {
            const valueDiv = document.getElementById(`value-${key}`);
            const input = document.getElementById(`input-${key}`);
            
            if (valueDiv && input) {
                valueDiv.style.display = 'block';
                input.style.display = 'none';
            }
        }
        
        function updateExtractedData(key, value) {
            // Pour le segment, pas de conversion nécessaire
            if (key === 'segment') {
                extractedData[key] = value;
                
                // Réinitialiser les prix pour éviter des conflits
                if (value === 'C5-BASE') {
                    // Supprimer les prix HP/HC si on passe en BASE
                    delete extractedData.prix_hp_centimes;
                    delete extractedData.prix_hc_centimes;
                } else if (value === 'C5-HPHC') {
                    // Supprimer le prix BASE si on passe en HP/HC
                    delete extractedData.prix_base_centimes;
                } else if (value === 'C4') {
                    // Supprimer les prix non-C4
                    delete extractedData.prix_base_centimes;
                    delete extractedData.prix_hp_centimes;
                    delete extractedData.prix_hc_centimes;
                    delete extractedData.prix_pointe_centimes;
                } else if (value === 'C2') {
                    // Supprimer les prix non-C2
                    delete extractedData.prix_base_centimes;
                    delete extractedData.prix_hp_centimes;
                    delete extractedData.prix_hc_centimes;
                } else if (value === 'GAZ') {
                    // Supprimer tous les prix électriques
                    delete extractedData.prix_base_centimes;
                    delete extractedData.prix_hp_centimes;
                    delete extractedData.prix_hc_centimes;
                    delete extractedData.prix_hpe_centimes;
                    delete extractedData.prix_hce_centimes;
                    delete extractedData.prix_hph_centimes;
                    delete extractedData.prix_hch_centimes;
                    delete extractedData.prix_pointe_centimes;
                }
            } else {
                // Appliquer les conversions si nécessaire
                const convertedValue = updateExtractedDataWithConversion(key, value);
                extractedData[key] = convertedValue;
            }
            
            // Recheck validation status
            setTimeout(() => {
                displayExtractedData();
                validateAllData();
            }, 100);
        }
        
        function validateAllData() {
            let allComplete = true;
            let message = '';
            
            // Vérifier les champs obligatoires
            const requiredFields = ['nom_client', 'siren', 'pdl_pce', 'segment', 'date_fin_contrat'];
            const missingRequired = requiredFields.filter(field => !extractedData[field] || extractedData[field] === 'N/A');
            
            if (missingRequired.length > 0) {
                allComplete = false;
                message += `Champs obligatoires manquants: ${missingRequired.join(', ')}. `;
            }
            
            // Vérifier les prix selon le segment
            let requiredPrix = [];
            if (extractedData.segment === 'GAZ') {
                requiredPrix = ['prix_molecule_eur_mwh', 'prix_abonnement_eur'];
            } else if (extractedData.segment === 'C5-BASE') {
                requiredPrix = ['prix_base_centimes', 'prix_abonnement_eur'];
            } else if (extractedData.segment === 'C5-HPHC') {
                requiredPrix = ['prix_hp_centimes', 'prix_hc_centimes', 'prix_abonnement_eur'];
            } else if (extractedData.segment === 'C4') {
                requiredPrix = ['prix_hpe_centimes', 'prix_hce_centimes', 'prix_hph_centimes', 'prix_hch_centimes', 'prix_abonnement_eur'];
            } else if (extractedData.segment === 'C2') {
                requiredPrix = ['prix_hpe_centimes', 'prix_hce_centimes', 'prix_hph_centimes', 'prix_hch_centimes', 'prix_pointe_centimes', 'prix_abonnement_eur'];
            }
            
            const missingPrix = requiredPrix.filter(field => !extractedData[field] && extractedData[field] !== 0);
            
            if (missingPrix.length > 0) {
                allComplete = false;
                message += `Prix manquants: ${missingPrix.join(', ')}.`;
            }
            
            const statusDiv = document.getElementById('extractionStatus');
            const statusText = document.getElementById('extractionStatusText');
            
            if (allComplete) {
                statusDiv.className = 'validation-banner';
                statusText.textContent = '✅ Toutes les données sont complètes ! Prêt pour le comparatif.';
                validationStatus.dataComplete = true;
                validationStatus.prixComplete = true;
                document.getElementById('nextToVolumes').disabled = false;
            } else {
                statusDiv.className = 'validation-banner error';
                statusText.textContent = `❌ ${message}`;
                document.getElementById('nextToVolumes').disabled = true;
            }
        }
        
        // Modal RGPD
        function showRGPDModal() {
            if (!extractedData) {
                alert('Aucune donnée extraite');
                return;
            }
            
            // Pré-remplir avec les données extraites
            if (extractedData.siren) {
                document.getElementById('clientSiren').value = extractedData.siren;
            }
            
            document.getElementById('rgpdModal').style.display = 'block';
        }
        
        function closeRGPDModal() {
            document.getElementById('rgpdModal').style.display = 'none';
        }
        
        function generateRGPDPDF() {
            const form = document.getElementById('rgpdForm');
            
            if (!form.checkValidity()) {
                alert('Veuillez remplir tous les champs obligatoires');
                return;
            }
            
            if (!document.getElementById('rgpdConsent').checked) {
                alert('Veuillez cocher la case de consentement RGPD');
                return;
            }
            
            // Récupérer la civilité sélectionnée
            const civiliteRadio = document.querySelector('input[name="civilite"]:checked');
            if (!civiliteRadio) {
                alert('Veuillez sélectionner une civilité');
                return;
            }
            
            const formData = {
                civilite: civiliteRadio.value,
                gerantNom: document.getElementById('gerantNom').value,
                gerantPrenom: document.getElementById('gerantPrenom').value,
                gerantEmail: document.getElementById('gerantEmail').value,
                gerantTelephone: document.getElementById('gerantTelephone').value,
                clientSiren: document.getElementById('clientSiren').value || extractedData.siren
            };
            
            // Sauvegarder les données du gérant
            gerantData = formData;
            
            // Génération PDF RGPD COMPLET avec jsPDF
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            
            // En-tête EcoGies complet
            doc.setFillColor(30, 58, 138);
            doc.rect(0, 0, 210, 50, 'F');
            
            doc.setFontSize(28);
            doc.setTextColor(255, 255, 255);
            doc.setFont(undefined, 'bold');
            doc.text('ECOGIES', 20, 25);
            
            doc.setFontSize(14);
            doc.setFont(undefined, 'normal');
            doc.text('COURTIER EN ÉNERGIES', 20, 35);
            
            doc.setFontSize(10);
            doc.text('Tél: 09 84 32 74 25 | 13 Bis rue George SAND, 94500 Champigny-Sur-Marne | Email: bo@ecogies.fr', 20, 45);
            
            // Titre
            doc.setFontSize(16);
            doc.setTextColor(0, 0, 0);
            doc.setFont(undefined, 'bold');
            doc.text('DOCUMENT RGPD - CONSENTEMENT DONNÉES ÉNERGÉTIQUES', 20, 65);
            
            // Informations société
            doc.setFontSize(12);
            doc.setFont(undefined, 'bold');
            doc.text('INFORMATIONS SOCIÉTÉ :', 20, 85);
            doc.setFont(undefined, 'normal');
            doc.text(`• Nom : ${extractedData.nom_client}`, 20, 95);
            doc.text(`• SIREN : ${formData.clientSiren}`, 20, 105);
            doc.text(`• PDL/PCE : ${extractedData.pdl_pce}`, 20, 115);
            doc.text(`• Segment : ${extractedData.segment}`, 20, 125);
            doc.text(`• Puissance : ${extractedData.puissance_souscrite} kVA`, 20, 135);
            doc.text(`• Adresse consommation : ${extractedData.adresse_consommation}`, 20, 145);
            
            // Informations gérant
            doc.setFont(undefined, 'bold');
            doc.text('INFORMATIONS GÉRANT :', 20, 165);
            doc.setFont(undefined, 'normal');
            doc.text(`• Civilité : ${formData.civilite}`, 20, 175);
            doc.text(`• Nom : ${formData.gerantNom.toUpperCase()} ${formData.gerantPrenom}`, 20, 185);
            doc.text(`• Email : ${formData.gerantEmail}`, 20, 195);
            doc.text(`• Téléphone : ${formData.gerantTelephone}`, 20, 205);
            
            // Nouvelle page pour le texte RGPD
            doc.addPage();
            
            // Titre consentement
            doc.setFontSize(14);
            doc.setFont(undefined, 'bold');
            doc.text('CONSENTEMENT RGPD', 20, 30);
            
            // Texte RGPD complet
            doc.setFontSize(10);
            doc.setFont(undefined, 'normal');
            
            const rgpdText = `En activant l'option ci-dessous, je donne mon accord à ECOGIES pour qu'elle puisse accéder et exploiter les informations techniques issues de mes compteurs, incluant l'historique de ma consommation, et spécifiquement pour recueillir mon adresse email dans le cadre de communications et de relances par email, en respectant les dispositions de la Réglementation Générale sur la Protection des Données (RGPD).

Par cette action, je donne mon consentement explicite pour que Ecogies recueille, traite, et utilise les données et informations techniques de mes compteurs à des fins d'analyse de mes habitudes de consommation et pour l'envoi d'emails personnalisés relatifs à leurs services énergétiques. Ces données, y compris mon adresse email, seront conservées le temps nécessaire, conformément aux lois applicables.

Je suis conscient(e) que je peux retirer mon consentement concernant l'utilisation de mon adresse email et des autres données à tout moment en adressant une demande écrite à bo@ecogies.fr. La rétraction de mon consentement n'influencera pas la légitimité du traitement effectué avant cette rétraction.

En activant cette option, je confirme avoir pris connaissance, compris et accepté les termes de ce consentement conforme au RGPD, incluant la collecte et l'utilisation de mon adresse email pour la relance par mailing.`;
            
            const splitText = doc.splitTextToSize(rgpdText, 170);
            doc.text(splitText, 20, 50);
            
            // Validation
            doc.setFontSize(14);
            doc.setFont(undefined, 'bold');
            doc.text('VALIDATION :', 20, 200);
            
            // Case cochée
            doc.setFillColor(16, 185, 129);
            doc.rect(20, 210, 8, 8, 'F');
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(12);
            doc.text('✓', 22, 217);
            
            doc.setTextColor(0, 0, 0);
            doc.setFont(undefined, 'bold');
            doc.text('ACCEPTED - CONSENTEMENT RGPD', 35, 217);
            
            doc.setFont(undefined, 'normal');
            doc.text(`Date de validation : ${new Date().toLocaleDateString('fr-FR')}`, 20, 230);
            doc.text('Signature gérant : ________________________________', 20, 245);
            
            // Pied de page
            doc.setFontSize(8);
            doc.text('Contact DPO : bo@ecogies.fr | Réclamations CNIL possibles', 20, 280);
            
            // Sauvegarde
            const fileName = `RGPD_${extractedData.nom_client.replace(/[^a-zA-Z0-9]/g, '_')}_${new Date().toISOString().split('T')[0]}.pdf`;
            doc.save(fileName);
            
            closeRGPDModal();
            alert('Document RGPD complet généré avec succès !');
        }
        
        // Étape 3 - Volumes
        function initVolumeStep() {
            const segment = extractedData.segment;
            document.getElementById('segmentDetected').textContent = segment;
            
            const tbody = document.getElementById('volumeTableBody');
            const thead = document.querySelector('#volumeTable thead tr');
            
            // Configuration des colonnes selon le segment
            let columns = ['col1Header'];
            let headers = ['Volume Total'];
            
            if (segment === 'C5-HPHC') {
                columns = ['col1Header', 'col2Header'];
                headers = ['HP', 'HC'];
            } else if (segment === 'C4') {
                columns = ['col1Header', 'col2Header', 'col3Header', 'col4Header'];
                headers = ['HPE', 'HCE', 'HPH', 'HCH'];
            } else if (segment === 'C2') {
                columns = ['col1Header', 'col2Header', 'col3Header', 'col4Header', 'col5Header'];
                headers = ['HPE', 'HCE', 'HPH', 'HCH', 'POINTE'];
            }
            
            // Reconstruire le header avec bouton + Année
            let headerHTML = '<th>Année</th>';
            headers.forEach(header => {
                headerHTML += `<th>${header}</th>`;
            });
            headerHTML += '<th>Total</th>';
            headerHTML += '<th><button onclick="addVolumeYear()" class="btn-add-year" style="padding: 5px 10px; background: #3b82f6; color: white; border: none; border-radius: 4px; cursor: pointer;">+ Année</button></th>';
            thead.innerHTML = headerHTML;
            
            // Stocker les headers pour utilisation ultérieure
            window.volumeHeaders = headers;
            window.volumeColumns = columns.length;
            
            // Générer les lignes pour 4 années
            tbody.innerHTML = '';
            for (let year = 2025; year <= 2028; year++) {
                addVolumeRow(year);
            }
        }
        
        function addVolumeRow(year) {
            const tbody = document.getElementById('volumeTableBody');
            const row = document.createElement('tr');
            let cellsHTML = `<td><strong>${year}</strong></td>`;
            
            for (let i = 0; i < window.volumeColumns; i++) {
                cellsHTML += `<td><input type="number" class="volume-input" data-year="${year}" data-column="col${i}" placeholder="0.00" step="0.01" onchange="updateVolumeTotal(${year})"></td>`;
            }
            
            cellsHTML += `<td id="total-${year}"><strong>0.00 MWh</strong></td>`;
            cellsHTML += '<td></td>'; // Colonne vide pour le bouton
            row.innerHTML = cellsHTML;
            tbody.appendChild(row);
        }
        
        function addVolumeYear() {
            const tbody = document.getElementById('volumeTableBody');
            const lastRow = tbody.lastElementChild;
            const lastYear = parseInt(lastRow.querySelector('td strong').textContent);
            const newYear = lastYear + 1;
            
            addVolumeRow(newYear);
        }
        
        function updateVolumeTotal(year) {
            const inputs = document.querySelectorAll(`input[data-year="${year}"]`);
            let total = 0;
            
            inputs.forEach(input => {
                total += parseFloat(input.value) || 0;
            });
            
            document.getElementById(`total-${year}`).innerHTML = `<strong>${total.toFixed(2)} MWh</strong>`;
        }
        
        function calculateVolumes() {
            // Collecter toutes les données de volumes pour toutes les années présentes
            volumeData = {};
            
            // Récupérer toutes les années uniques
            const years = new Set();
            document.querySelectorAll('.volume-input').forEach(input => {
                years.add(parseInt(input.dataset.year));
            });
            
            // Collecter les données pour chaque année
            years.forEach(year => {
                volumeData[year] = {};
                const inputs = document.querySelectorAll(`input[data-year="${year}"]`);
                
                inputs.forEach(input => {
                    const column = input.dataset.column;
                    volumeData[year][column] = parseFloat(input.value) || 0;
                });
            });
            
            console.log('Volumes calculés:', volumeData);
            alert('Volumes calculés avec succès !');
        }
        
        // Étape 4 - Prix OHM
        function selectAbonnement(prix) {
            selectedAbonnement = prix;
            
            document.querySelectorAll('.abonnement-option').forEach(opt => opt.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
        }
        
        function initPrixStep() {
            const segment = extractedData.segment;
            const tbody = document.getElementById('prixOhmTableBody');
            const thead = document.querySelector('#prixOhmTable thead tr');
            
            let postes = [];
            
            // TOUJOURS afficher en €/MWh pour cohérence
            if (segment === 'GAZ') {
                postes = [
                    { key: 'prix_molecule', label: 'Prix molécule', unit: '€/MWh', isGaz: true }
                ];
            } else if (segment === 'C5-BASE') {
                postes = [
                    { key: 'prix_base', label: 'Prix BASE', unit: '€/MWh' }
                ];
            } else if (segment === 'C5-HPHC') {
                postes = [
                    { key: 'prix_hp', label: 'Prix HP', unit: '€/MWh' },
                    { key: 'prix_hc', label: 'Prix HC', unit: '€/MWh' }
                ];
            } else if (segment === 'C4') {
                postes = [
                    { key: 'prix_hpe', label: 'Prix HPE', unit: '€/MWh' },
                    { key: 'prix_hce', label: 'Prix HCE', unit: '€/MWh' },
                    { key: 'prix_hph', label: 'Prix HPH', unit: '€/MWh' },
                    { key: 'prix_hch', label: 'Prix HCH', unit: '€/MWh' }
                ];
            } else if (segment === 'C2') {
                postes = [
                    { key: 'prix_hpe', label: 'Prix HPE', unit: '€/MWh' },
                    { key: 'prix_hce', label: 'Prix HCE', unit: '€/MWh' },
                    { key: 'prix_hph', label: 'Prix HPH', unit: '€/MWh' },
                    { key: 'prix_hch', label: 'Prix HCH', unit: '€/MWh' },
                    { key: 'prix_pointe', label: 'Prix POINTE', unit: '€/MWh' }
                ];
            }
            
            // Réinitialiser le header avec années dynamiques
            const currentYears = [2025, 2026, 2027, 2028];
            thead.innerHTML = `
                <th>Type de prix</th>
                ${currentYears.map(year => `<th>${year}</th>`).join('')}
                <th>Moyenne</th>
                <th><button onclick="addPrixYear()" class="btn-add-year" style="padding: 5px 10px; background: #3b82f6; color: white; border: none; border-radius: 4px; cursor: pointer;">+ Année</button></th>
            `;
            
            tbody.innerHTML = '';
            
            postes.forEach(poste => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><strong>${poste.label} (${poste.unit})</strong></td>
                    ${currentYears.map(year => `
                        <td><input type="number" class="prix-ohm-input" 
                            data-poste="${poste.key}" 
                            data-year="${year}" 
                            data-unit="${poste.unit}"
                            data-is-gaz="${poste.isGaz || false}"
                            step="0.01" 
                            placeholder="0.00"
                            onchange="updatePrixMoyenne('${poste.key}')"></td>
                    `).join('')}
                    <td id="moyenne-${poste.key}"><strong>0.00</strong></td>
                    <td></td>
                `;
                tbody.appendChild(row);
            });
        }
        
        function addPrixYear() {
            const thead = document.querySelector('#prixOhmTable thead tr');
            const tbody = document.getElementById('prixOhmTableBody');
            
            // Trouver la dernière année
            const thElements = thead.querySelectorAll('th');
            let lastYear = 2028;
            for (let i = 1; i < thElements.length - 2; i++) {
                const year = parseInt(thElements[i].textContent);
                if (!isNaN(year) && year > lastYear) {
                    lastYear = year;
                }
            }
            
            const newYear = lastYear + 1;
            
            // Ajouter colonne dans le header
            const moyenneIndex = thElements.length - 2;
            const newTh = document.createElement('th');
            newTh.textContent = newYear;
            thead.insertBefore(newTh, thElements[moyenneIndex]);
            
            // Ajouter colonne dans chaque ligne
            tbody.querySelectorAll('tr').forEach(row => {
                const cells = row.querySelectorAll('td');
                const moyenneCell = cells[cells.length - 2];
                const poste = row.querySelector('.prix-ohm-input')?.dataset.poste;
                const unit = row.querySelector('.prix-ohm-input')?.dataset.unit;
                const isGaz = row.querySelector('.prix-ohm-input')?.dataset.isGaz;
                
                if (poste) {
                    const newCell = document.createElement('td');
                    newCell.innerHTML = `
                        <input type="number" class="prix-ohm-input" 
                            data-poste="${poste}" 
                            data-year="${newYear}"
                            data-unit="${unit}"
                            data-is-gaz="${isGaz}"
                            step="0.01" 
                            placeholder="0.00"
                            onchange="updatePrixMoyenne('${poste}')">
                    `;
                    row.insertBefore(newCell, moyenneCell);
                }
            });
        }
        
        function updatePrixMoyenne(poste) {
            const inputs = document.querySelectorAll(`input[data-poste="${poste}"]`);
            let total = 0;
            let count = 0;
            
            inputs.forEach(input => {
                const value = parseFloat(input.value);
                if (!isNaN(value)) {
                    total += value;
                    count++;
                }
            });
            
            const moyenne = count > 0 ? total / count : 0;
            document.getElementById(`moyenne-${poste}`).innerHTML = `<strong>${moyenne.toFixed(2)}</strong>`;
        }
        
        function calculatePrixMoyens() {
            // Collecter les prix OHM et calculer moyennes
            prixOhmData = {
                abonnement: selectedAbonnement,
                moyennes: {}
            };
            
            const postes = new Set();
            document.querySelectorAll('.prix-ohm-input').forEach(input => {
                postes.add(input.dataset.poste);
            });
            
            postes.forEach(poste => {
                const inputs = document.querySelectorAll(`input[data-poste="${poste}"]`);
                let total = 0;
                let count = 0;
                const isGaz = inputs[0]?.dataset.isGaz === 'true';
                
                inputs.forEach(input => {
                    let value = parseFloat(input.value);
                    if (!isNaN(value)) {
                        // Les prix sont saisis en €/MWh dans l'interface
                        // Pour l'électricité, on les convertit en c€/kWh pour le stockage interne
                        // Pour le gaz, on garde en €/MWh
                        if (!isGaz && poste !== 'prix_molecule') {
                            // Conversion €/MWh → c€/kWh (÷10) pour stockage interne
                            value = value / 10;
                        }
                        total += value;
                        count++;
                    }
                });
                
                const moyenne = count > 0 ? total / count : 0;
                prixOhmData.moyennes[poste] = moyenne;
                
                // Afficher la moyenne en €/MWh dans l'interface
                const displayMoyenne = isGaz || poste === 'prix_molecule' ? moyenne : moyenne * 10;
                document.getElementById(`moyenne-${poste}`).innerHTML = `<strong>${displayMoyenne.toFixed(2)}</strong>`;
            });
            
            console.log('Prix OHM calculés (stockage interne):', prixOhmData);
            alert('Moyennes des prix OHM calculées avec succès !');
        }
        
        // Étape 5 - Comparatif
        function initComparatifStep() {
            // Afficher infos client
            const clientGrid = document.getElementById('clientInfoGrid');
            clientGrid.innerHTML = `
                <div class="client-info-item">
                    <strong>Société :</strong> ${extractedData.nom_client}
                </div>
                <div class="client-info-item">
                    <strong>SIREN :</strong> ${extractedData.siren}
                </div>
                <div class="client-info-item">
                    <strong>${selectedEnergy === 'gas' ? 'PCE' : 'PDL'} :</strong> ${extractedData.pdl_pce}
                </div>
                <div class="client-info-item">
                    <strong>Segment :</strong> ${extractedData.segment}${selectedEnergy !== 'gas' && extractedData.puissance_souscrite ? ` - ${extractedData.puissance_souscrite} kVA` : ''}${selectedEnergy === 'gas' && extractedData.car ? ` - CAR: ${extractedData.car} MWh/an` : ''}
                </div>
                <div class="client-info-item">
                    <strong>Adresse :</strong> ${extractedData.adresse_consommation}
                </div>
                <div class="client-info-item">
                    <strong>Fournisseur :</strong> ${extractedData.fournisseur}
                </div>
                <div class="client-info-item">
                    <strong>Fin contrat :</strong> ${extractedData.date_fin_contrat}
                </div>
            `;
            
            // Calculer les économies réelles (permettre négatif si surcoût)
            const currentCost = calculateCurrentCost();
            const ohmCost = calculateOhmCost();
            const savings = currentCost - ohmCost;
            const savingsPercent = currentCost > 0 ? ((savings / currentCost) * 100).toFixed(1) : 0;
            
            // Adapter l'affichage selon économies positives ou négatives
            const economiesSection = document.querySelector('.economies-banner');
            const economiesAmount = document.getElementById('economiesAmount');
            const economiesPercent = document.getElementById('economiesPercent');
            
            if (savings < 0) {
                // Surcoût - affichage rouge
                economiesSection.style.background = 'linear-gradient(135deg, #ef4444 0%, #dc2626 100%)';
                economiesAmount.textContent = `+${Math.abs(savings).toFixed(0)}€`;
                economiesPercent.textContent = `${Math.abs(savingsPercent)}% de surcoût`;
            } else {
                // Économies - affichage vert
                economiesSection.style.background = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
                economiesAmount.textContent = `${savings.toFixed(0)}€`;
                economiesPercent.textContent = `${savingsPercent}% d'économies`;
            }
            
            // Remplir le tableau comparatif détaillé
            generateComparatifTable();
        }
        
        function calculateCurrentCost() {
            let cost = parseFloat(extractedData.prix_abonnement_eur) || 0;
            
            // Calculer selon le segment avec logique correcte
            if (extractedData.segment === 'GAZ') {
                // Volume en MWh × prix en €/MWh
                const avgVolume = getAverageVolume('col0');
                cost += avgVolume * (parseFloat(extractedData.prix_molecule_eur_mwh) || 0);
                
            } else if (extractedData.segment === 'C5-BASE') {
                const avgVolume = getAverageVolume('col0');
                // Conversion c€/kWh vers €/MWh : ×10
                cost += avgVolume * ((parseFloat(extractedData.prix_base_centimes) || 0) * 10);
                
            } else if (extractedData.segment === 'C5-HPHC') {
                const avgVolumeHP = getAverageVolume('col0');
                const avgVolumeHC = getAverageVolume('col1');
                // Conversion c€/kWh vers €/MWh : ×10
                cost += avgVolumeHP * ((parseFloat(extractedData.prix_hp_centimes) || 0) * 10);
                cost += avgVolumeHC * ((parseFloat(extractedData.prix_hc_centimes) || 0) * 10);
                
            } else if (extractedData.segment === 'C4') {
                // LES 4 POSTES C4 OBLIGATOIRES
                const avgVolumeHPE = getAverageVolume('col0');
                const avgVolumeHCE = getAverageVolume('col1');
                const avgVolumeHPH = getAverageVolume('col2');
                const avgVolumeHCH = getAverageVolume('col3');
                
                // Conversion c€/kWh vers €/MWh : ×10
                cost += avgVolumeHPE * ((parseFloat(extractedData.prix_hpe_centimes) || 0) * 10);
                cost += avgVolumeHCE * ((parseFloat(extractedData.prix_hce_centimes) || 0) * 10);
                cost += avgVolumeHPH * ((parseFloat(extractedData.prix_hph_centimes) || 0) * 10);
                cost += avgVolumeHCH * ((parseFloat(extractedData.prix_hch_centimes) || 0) * 10);
                
            } else if (extractedData.segment === 'C2') {
                // LES 5 POSTES C2 OBLIGATOIRES
                const avgVolumeHPE = getAverageVolume('col0');
                const avgVolumeHCE = getAverageVolume('col1');
                const avgVolumeHPH = getAverageVolume('col2');
                const avgVolumeHCH = getAverageVolume('col3');
                const avgVolumePointe = getAverageVolume('col4');
                
                // Conversion c€/kWh vers €/MWh : ×10
                cost += avgVolumeHPE * ((parseFloat(extractedData.prix_hpe_centimes) || 0) * 10);
                cost += avgVolumeHCE * ((parseFloat(extractedData.prix_hce_centimes) || 0) * 10);
                cost += avgVolumeHPH * ((parseFloat(extractedData.prix_hph_centimes) || 0) * 10);
                cost += avgVolumeHCH * ((parseFloat(extractedData.prix_hch_centimes) || 0) * 10);
                cost += avgVolumePointe * ((parseFloat(extractedData.prix_pointe_centimes) || 0) * 10);
            }
            
            return cost;
        }
        
        function calculateOhmCost() {
            let cost = selectedAbonnement || 0;
            
            // Calculer selon le segment avec logique correcte
            if (extractedData.segment === 'GAZ') {
                const avgVolume = getAverageVolume('col0');
                // Volume en MWh × prix en €/MWh
                cost += avgVolume * (prixOhmData.moyennes?.prix_molecule || 0);
                
            } else if (extractedData.segment === 'C5-BASE') {
                const avgVolume = getAverageVolume('col0');
                // Conversion c€/kWh vers €/MWh : ×10
                cost += avgVolume * ((prixOhmData.moyennes?.prix_base || 0) * 10);
                
            } else if (extractedData.segment === 'C5-HPHC') {
                const avgVolumeHP = getAverageVolume('col0');
                const avgVolumeHC = getAverageVolume('col1');
                // Conversion c€/kWh vers €/MWh : ×10
                cost += avgVolumeHP * ((prixOhmData.moyennes?.prix_hp || 0) * 10);
                cost += avgVolumeHC * ((prixOhmData.moyennes?.prix_hc || 0) * 10);
                
            } else if (extractedData.segment === 'C4') {
                // LES 4 POSTES C4 OBLIGATOIRES
                const avgVolumeHPE = getAverageVolume('col0');
                const avgVolumeHCE = getAverageVolume('col1');
                const avgVolumeHPH = getAverageVolume('col2');
                const avgVolumeHCH = getAverageVolume('col3');
                
                // Conversion c€/kWh vers €/MWh : ×10
                cost += avgVolumeHPE * ((prixOhmData.moyennes?.prix_hpe || 0) * 10);
                cost += avgVolumeHCE * ((prixOhmData.moyennes?.prix_hce || 0) * 10);
                cost += avgVolumeHPH * ((prixOhmData.moyennes?.prix_hph || 0) * 10);
                cost += avgVolumeHCH * ((prixOhmData.moyennes?.prix_hch || 0) * 10);
                
            } else if (extractedData.segment === 'C2') {
                // LES 5 POSTES C2 OBLIGATOIRES
                const avgVolumeHPE = getAverageVolume('col0');
                const avgVolumeHCE = getAverageVolume('col1');
                const avgVolumeHPH = getAverageVolume('col2');
                const avgVolumeHCH = getAverageVolume('col3');
                const avgVolumePointe = getAverageVolume('col4');
                
                // Conversion c€/kWh vers €/MWh : ×10
                cost += avgVolumeHPE * ((prixOhmData.moyennes?.prix_hpe || 0) * 10);
                cost += avgVolumeHCE * ((prixOhmData.moyennes?.prix_hce || 0) * 10);
                cost += avgVolumeHPH * ((prixOhmData.moyennes?.prix_hph || 0) * 10);
                cost += avgVolumeHCH * ((prixOhmData.moyennes?.prix_hch || 0) * 10);
                cost += avgVolumePointe * ((prixOhmData.moyennes?.prix_pointe || 0) * 10);
            }
            
            return cost;
        }
        
        function getAverageVolume(column) {
            let total = 0;
            let count = 0;
            
            Object.values(volumeData).forEach(yearData => {
                if (yearData[column] !== undefined) {
                    total += yearData[column];
                    count++;
                }
            });
            
            return count > 0 ? total / count : 0;
        }
        
        function generateComparatifTable() {
            const tbody = document.getElementById('comparatifTableBody');
            tbody.innerHTML = '';
            
            // Variables pour les totaux
            let totalCoutClient = 0;
            let totalCoutOhm = 0;
            
            // ABONNEMENT
            const abonnementClient = parseFloat(extractedData.prix_abonnement_eur) || 0;
            const abonnementOhm = selectedAbonnement || 0;
            const abonnementEconomie = abonnementClient - abonnementOhm;
            
            totalCoutClient += abonnementClient;
            totalCoutOhm += abonnementOhm;
            
            const abonnementRow = document.createElement('tr');
            abonnementRow.innerHTML = `
                <td><strong>Abonnement</strong></td>
                <td>${Math.round(abonnementClient)}€/an</td>
                <td style="color: #10b981;"><strong>${Math.round(abonnementOhm)}€/an</strong></td>
                <td style="color: ${abonnementEconomie >= 0 ? '#10b981' : '#ef4444'};"><strong>${Math.round(abonnementEconomie)}€</strong></td>
            `;
            tbody.appendChild(abonnementRow);
            
            // ENERGIE selon segment
            if (extractedData.segment === 'GAZ') {
                const avgVolume = getAverageVolume('col0');
                const prixClientMolecule = parseFloat(extractedData.prix_molecule_eur_mwh) || 0;
                const prixOhmMolecule = prixOhmData.moyennes?.prix_molecule || 0;
                
                // Calculs corrects : volume en MWh × prix en €/MWh
                const coutClientMolecule = avgVolume * prixClientMolecule;
                const coutOhmMolecule = avgVolume * prixOhmMolecule;
                const economieMolecule = coutClientMolecule - coutOhmMolecule;
                
                totalCoutClient += coutClientMolecule;
                totalCoutOhm += coutOhmMolecule;
                
                const moleculeRow = document.createElement('tr');
                moleculeRow.innerHTML = `
                    <td><strong>Molécule (${avgVolume.toFixed(1)} MWh)</strong></td>
                    <td>${prixClientMolecule.toFixed(2)} €/MWh → ${Math.round(coutClientMolecule)}€</td>
                    <td style="color: #10b981;"><strong>${prixOhmMolecule.toFixed(2)} €/MWh → ${Math.round(coutOhmMolecule)}€</strong></td>
                    <td style="color: ${economieMolecule >= 0 ? '#10b981' : '#ef4444'};"><strong>${Math.round(economieMolecule)}€</strong></td>
                `;
                tbody.appendChild(moleculeRow);
                
            } else if (extractedData.segment === 'C5-BASE') {
                // BASE
                const avgVolume = getAverageVolume('col0');
                const prixClientBase = parseFloat(extractedData.prix_base_centimes) || 0;
                const prixOhmBase = prixOhmData.moyennes?.prix_base || 0;
                
                // Conversion c€/kWh vers €/MWh : ×10
                const coutClientBase = avgVolume * (prixClientBase * 10);
                const coutOhmBase = avgVolume * (prixOhmBase * 10);
                const economieBase = coutClientBase - coutOhmBase;
                
                totalCoutClient += coutClientBase;
                totalCoutOhm += coutOhmBase;
                
                const baseRow = document.createElement('tr');
                baseRow.innerHTML = `
                    <td><strong>BASE (${avgVolume.toFixed(1)} MWh)</strong></td>
                    <td>${prixClientBase.toFixed(2)} c€/kWh → ${Math.round(coutClientBase)}€</td>
                    <td style="color: #10b981;"><strong>${prixOhmBase.toFixed(2)} c€/kWh → ${Math.round(coutOhmBase)}€</strong></td>
                    <td style="color: ${economieBase >= 0 ? '#10b981' : '#ef4444'};"><strong>${Math.round(economieBase)}€</strong></td>
                `;
                tbody.appendChild(baseRow);
                
            } else if (extractedData.segment === 'C5-HPHC') {
                // HP
                const avgVolumeHP = getAverageVolume('col0');
                const prixClientHP = parseFloat(extractedData.prix_hp_centimes) || 0;
                const prixOhmHP = prixOhmData.moyennes?.prix_hp || 0;
                
                // Conversion c€/kWh vers €/MWh : ×10
                const coutClientHP = avgVolumeHP * (prixClientHP * 10);
                const coutOhmHP = avgVolumeHP * (prixOhmHP * 10);
                const economieHP = coutClientHP - coutOhmHP;
                
                totalCoutClient += coutClientHP;
                totalCoutOhm += coutOhmHP;
                
                const hpRow = document.createElement('tr');
                hpRow.innerHTML = `
                    <td><strong>HP (${avgVolumeHP.toFixed(1)} MWh)</strong></td>
                    <td>${prixClientHP.toFixed(2)} c€/kWh → ${Math.round(coutClientHP)}€</td>
                    <td style="color: #10b981;"><strong>${prixOhmHP.toFixed(2)} c€/kWh → ${Math.round(coutOhmHP)}€</strong></td>
                    <td style="color: ${economieHP >= 0 ? '#10b981' : '#ef4444'};"><strong>${Math.round(economieHP)}€</strong></td>
                `;
                tbody.appendChild(hpRow);
                
                // HC
                const avgVolumeHC = getAverageVolume('col1');
                const prixClientHC = parseFloat(extractedData.prix_hc_centimes) || 0;
                const prixOhmHC = prixOhmData.moyennes?.prix_hc || 0;
                
                // Conversion c€/kWh vers €/MWh : ×10
                const coutClientHC = avgVolumeHC * (prixClientHC * 10);
                const coutOhmHC = avgVolumeHC * (prixOhmHC * 10);
                const economieHC = coutClientHC - coutOhmHC;
                
                totalCoutClient += coutClientHC;
                totalCoutOhm += coutOhmHC;
                
                const hcRow = document.createElement('tr');
                hcRow.innerHTML = `
                    <td><strong>HC (${avgVolumeHC.toFixed(1)} MWh)</strong></td>
                    <td>${prixClientHC.toFixed(2)} c€/kWh → ${Math.round(coutClientHC)}€</td>
                    <td style="color: #10b981;"><strong>${prixOhmHC.toFixed(2)} c€/kWh → ${Math.round(coutOhmHC)}€</strong></td>
                    <td style="color: ${economieHC >= 0 ? '#10b981' : '#ef4444'};"><strong>${Math.round(economieHC)}€</strong></td>
                `;
                tbody.appendChild(hcRow);
                
            } else if (extractedData.segment === 'C4') {
                // LES 4 PRIX C4 OBLIGATOIRES
                const postes = [
                    { key: 'hpe', label: 'HPE', col: 'col0' },
                    { key: 'hce', label: 'HCE', col: 'col1' },
                    { key: 'hph', label: 'HPH', col: 'col2' },
                    { key: 'hch', label: 'HCH', col: 'col3' }
                ];
                
                postes.forEach(poste => {
                    const avgVolume = getAverageVolume(poste.col);
                    const prixClient = parseFloat(extractedData[`prix_${poste.key}_centimes`]) || 0;
                    const prixOhm = prixOhmData.moyennes?.[`prix_${poste.key}`] || 0;
                    
                    // Conversion c€/kWh vers €/MWh : ×10
                    const coutClient = avgVolume * (prixClient * 10);
                    const coutOhm = avgVolume * (prixOhm * 10);
                    const economie = coutClient - coutOhm;
                    
                    totalCoutClient += coutClient;
                    totalCoutOhm += coutOhm;
                    
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td><strong>${poste.label} (${avgVolume.toFixed(1)} MWh)</strong></td>
                        <td>${prixClient.toFixed(2)} c€/kWh → ${Math.round(coutClient)}€</td>
                        <td style="color: ${prixOhm < prixClient ? '#10b981' : '#ef4444'};"><strong>${prixOhm.toFixed(2)} c€/kWh → ${Math.round(coutOhm)}€</strong></td>
                        <td style="color: ${economie >= 0 ? '#10b981' : '#ef4444'};"><strong>${Math.round(economie)}€</strong></td>
                    `;
                    tbody.appendChild(row);
                });
                
            } else if (extractedData.segment === 'C2') {
                // LES 5 PRIX C2 OBLIGATOIRES
                const postes = [
                    { key: 'hpe', label: 'HPE', col: 'col0' },
                    { key: 'hce', label: 'HCE', col: 'col1' },
                    { key: 'hph', label: 'HPH', col: 'col2' },
                    { key: 'hch', label: 'HCH', col: 'col3' },
                    { key: 'pointe', label: 'POINTE', col: 'col4' }
                ];
                
                postes.forEach(poste => {
                    const avgVolume = getAverageVolume(poste.col);
                    const prixClient = parseFloat(extractedData[`prix_${poste.key}_centimes`]) || 0;
                    const prixOhm = prixOhmData.moyennes?.[`prix_${poste.key}`] || 0;
                    
                    // Conversion c€/kWh vers €/MWh : ×10
                    const coutClient = avgVolume * (prixClient * 10);
                    const coutOhm = avgVolume * (prixOhm * 10);
                    const economie = coutClient - coutOhm;
                    
                    totalCoutClient += coutClient;
                    totalCoutOhm += coutOhm;
                    
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td><strong>${poste.label} (${avgVolume.toFixed(1)} MWh)</strong></td>
                        <td>${prixClient.toFixed(2)} c€/kWh → ${Math.round(coutClient)}€</td>
                        <td style="color: ${prixOhm < prixClient ? '#10b981' : '#ef4444'};"><strong>${prixOhm.toFixed(2)} c€/kWh → ${Math.round(coutOhm)}€</strong></td>
                        <td style="color: ${economie >= 0 ? '#10b981' : '#ef4444'};"><strong>${Math.round(economie)}€</strong></td>
                    `;
                    tbody.appendChild(row);
                });
            }
            
            // TOTAL avec les vrais calculs
            const totalEconomies = totalCoutClient - totalCoutOhm;
            const pourcentageEconomie = totalCoutClient > 0 ? (totalEconomies / totalCoutClient * 100) : 0;
            
            const totalRow = document.createElement('tr');
            totalRow.style.background = '#f3f4f6';
            totalRow.style.fontWeight = 'bold';
            totalRow.innerHTML = `
                <td><strong>TOTAL ANNUEL</strong></td>
                <td><strong>${Math.round(totalCoutClient)}€</strong></td>
                <td style="color: ${totalCoutOhm < totalCoutClient ? '#10b981' : '#ef4444'};"><strong>${Math.round(totalCoutOhm)}€</strong></td>
                <td style="color: ${totalEconomies >= 0 ? '#10b981' : '#ef4444'};"><strong>${totalEconomies >= 0 ? '' : '+'}${Math.round(totalEconomies)}€ (${Math.abs(pourcentageEconomie).toFixed(1)}%)</strong></td>
            `;
            tbody.appendChild(totalRow);
        }
        
        function generateComparatifPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            
            // En-tête EcoGies stylé
            doc.setFillColor(30, 58, 138);
            doc.rect(0, 0, 210, 40, 'F');
            
            doc.setFontSize(24);
            doc.setTextColor(255, 255, 255);
            doc.setFont(undefined, 'bold');
            doc.text('ECOGIES', 20, 25);
            
            doc.setFontSize(14);
            doc.text('ÉTUDE COMPARATIVE ÉNERGÉTIQUE', 20, 35);
            
            // Zone client
            doc.setFillColor(240, 249, 255);
            doc.rect(20, 50, 170, 35, 'F');
            
            doc.setFontSize(12);
            doc.setTextColor(0, 0, 0);
            doc.setFont(undefined, 'bold');
            doc.text('INFORMATIONS CLIENT', 25, 60);
            doc.setFont(undefined, 'normal');
            doc.text(`Société : ${extractedData.nom_client}`, 25, 70);
            doc.text(`SIREN : ${extractedData.siren} | PDL : ${extractedData.pdl_pce}`, 25, 75);
            doc.text(`Segment : ${extractedData.segment} - ${extractedData.puissance_souscrite} kVA`, 25, 80);
            
            // Résumé des économies
            const savings = calculateCurrentCost() - calculateOhmCost();
            const savingsPercent = ((savings / calculateCurrentCost()) * 100).toFixed(1);
            
            doc.setFillColor(16, 185, 129);
            doc.rect(20, 95, 170, 15, 'F');
            doc.setFontSize(16);
            doc.setTextColor(255, 255, 255);
            doc.setFont(undefined, 'bold');
            doc.text(`ÉCONOMIES ANNUELLES : ${savings.toFixed(0)}€ (${savingsPercent}%)`, 25, 107);
            
            // Tableau comparatif
            doc.setFontSize(12);
            doc.setTextColor(0, 0, 0);
            doc.setFont(undefined, 'bold');
            doc.text('COMPARATIF DÉTAILLÉ :', 20, 125);
            
            const startY = 135;
            
            // En-têtes tableau
            doc.setFillColor(59, 130, 246);
            doc.rect(20, startY, 170, 8, 'F');
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(10);
            doc.text('Poste', 25, startY + 6);
            doc.text('Situation actuelle', 70, startY + 6);
            doc.text('Offre OHM', 120, startY + 6);
            doc.text('Économie', 160, startY + 6);
            
            // Données
            doc.setTextColor(0, 0, 0);
            doc.setFont(undefined, 'normal');
            let y = startY + 15;
            
            // Abonnement
            doc.text('Abonnement', 25, y);
            doc.text(`${extractedData.prix_abonnement_eur}€`, 70, y);
            doc.text(`${selectedAbonnement}€`, 120, y);
            doc.text(`${((extractedData.prix_abonnement_eur || 0) - selectedAbonnement).toFixed(0)}€`, 160, y);
            y += 10;
            
            // Consommation selon segment
            if (extractedData.segment === 'C5-HPHC') {
                const avgVolumeHP = getAverageVolume('col0');
                const avgVolumeHC = getAverageVolume('col1');
                
                doc.text(`HP (${avgVolumeHP.toFixed(1)} MWh)`, 25, y);
                doc.text(`${extractedData.prix_hp_centimes} c€/kWh`, 70, y);
                doc.text(`${(prixOhmData.moyennes?.prix_hp || 0).toFixed(2)} c€/kWh`, 120, y);
                y += 8;
                
                doc.text(`HC (${avgVolumeHC.toFixed(1)} MWh)`, 25, y);
                doc.text(`${extractedData.prix_hc_centimes} c€/kWh`, 70, y);
                doc.text(`${(prixOhmData.moyennes?.prix_hc || 0).toFixed(2)} c€/kWh`, 120, y);
                y += 8;
            }
            
            // Total
            doc.setFont(undefined, 'bold');
            doc.text('TOTAL ANNUEL', 25, y + 5);
            doc.text(`${calculateCurrentCost().toFixed(0)}€`, 70, y + 5);
            doc.text(`${calculateOhmCost().toFixed(0)}€`, 120, y + 5);
            doc.text(`${savings.toFixed(0)}€`, 160, y + 5);
            
            // Conditions
            doc.setFontSize(10);
            doc.setFont(undefined, 'normal');
            doc.text('Conditions : Prix fixe OHM Énergie, durée 24 mois', 20, 240);
            doc.text(`Date d'étude : ${new Date().toLocaleDateString('fr-FR')} | Contact : 09 84 32 74 25`, 20, 250);
            
            // Sauvegarde
            const fileName = `Comparatif_${extractedData.nom_client.replace(/[^a-zA-Z0-9]/g, '_')}_${new Date().toISOString().split('T')[0]}.pdf`;
            doc.save(fileName);
            
            alert('PDF Comparatif professionnel généré avec succès !');
        }
        
        // Étape 6 - MEC
        function selectFournisseur(fournisseur) {
            const card = event.currentTarget;
            
            if (selectedFournisseurs.includes(fournisseur)) {
                // Désélectionner
                selectedFournisseurs = selectedFournisseurs.filter(f => f !== fournisseur);
                card.classList.remove('selected');
            } else if (selectedFournisseurs.length < 5) {
                // Sélectionner
                selectedFournisseurs.push(fournisseur);
                card.classList.add('selected');
            } else {
                alert('Vous ne pouvez sélectionner que 5 fournisseurs maximum');
                return;
            }
            
            document.getElementById('selectedCount').textContent = selectedFournisseurs.length;
            
            // Activer/désactiver le bouton MEC
            const mecButton = document.getElementById('mecButton');
            if (selectedFournisseurs.length === 5) {
                mecButton.disabled = false;
                mecButton.style.opacity = '1';
            } else {
                mecButton.disabled = true;
                mecButton.style.opacity = '0.5';
            }
        }
        
        function generateMECPDF() {
            if (selectedFournisseurs.length !== 5) {
                alert('Veuillez sélectionner exactement 5 fournisseurs');
                return;
            }
            
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            
            // En-tête EcoGies professionnel style votre exemple
            doc.setFillColor(30, 58, 138);
            doc.rect(0, 0, 210, 45, 'F');
            
            doc.setFontSize(24);
            doc.setTextColor(255, 255, 255);
            doc.setFont(undefined, 'bold');
            doc.text('ECOGIES', 20, 25);
            
            doc.setFontSize(14);
            doc.text('MISE EN CONCURRENCE ÉNERGÉTIQUE', 20, 35);
            doc.setFontSize(10);
            doc.text(`Site 01 | CAR : ${extractedData.pdl_pce}`, 150, 35);
            
            // Zone client style votre exemple
            doc.setFillColor(255, 165, 0);
            doc.rect(20, 50, 170, 25, 'F');
            
            doc.setTextColor(0, 0, 0);
            doc.setFontSize(12);
            doc.setFont(undefined, 'bold');
            doc.text('IDENTIFICATION DE LA SOCIÉTÉ', 25, 60);
            doc.setFont(undefined, 'normal');
            doc.text(`Nom : ${extractedData.nom_client}`, 25, 67);
            doc.text(`SIREN : ${extractedData.siren} | ${extractedData.segment} | ${extractedData.puissance_souscrite} kVA`, 25, 72);
            
            // Tableau MEC style professionnel
            doc.setFont(undefined, 'bold');
            doc.text('COMPARATIF DES OFFRES :', 20, 90);
            
            const startY = 100;
            
            // En-têtes avec style
            doc.setFillColor(59, 130, 246);
            doc.rect(20, startY, 170, 12, 'F');
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(11);
            doc.text('Fournisseur', 25, startY + 8);
            doc.text('Abonnement', 70, startY + 8);
            doc.text('Prix énergie', 110, startY + 8);
            doc.text('Total annuel', 150, startY + 8);
            
            // OHM en première position (style gagnant)
            const ohmCost = calculateOhmCost();
            
            doc.setFillColor(16, 185, 129);
            doc.rect(20, startY + 12, 170, 12, 'F');
            doc.setTextColor(255, 255, 255);
            doc.setFont(undefined, 'bold');
            doc.text('OHM ÉNERGIE ★', 25, startY + 20);
            doc.text(`${selectedAbonnement}€`, 70, startY + 20);
            
            if (extractedData.segment === 'GAZ') {
                doc.text(`${(prixOhmData.moyennes?.prix_molecule || 0).toFixed(2)} €/MWh`, 110, startY + 20);
            } else if (extractedData.segment === 'C5-HPHC') {
                doc.text(`HP:${(prixOhmData.moyennes?.prix_hp || 0).toFixed(1)} HC:${(prixOhmData.moyennes?.prix_hc || 0).toFixed(1)}`, 110, startY + 20);
            }
            
            doc.text(`${ohmCost.toFixed(0)}€`, 150, startY + 20);
            
            // Concurrents (8-17% plus chers avec logos colorés)
            doc.setTextColor(0, 0, 0);
            doc.setFont(undefined, 'normal');
            
            const fournisseurColors = {
                'EDF': [59, 130, 246],
                'ENGIE': [0, 166, 80],
                'TOTALENERGIES': [255, 102, 0],
                'VATTENFALL': [139, 0, 0],
                'ENI': [255, 215, 0],
                'EKWATEUR': [50, 205, 50],
                'IBERDROLA': [0, 206, 209],
                'ALPIQ': [65, 105, 225]
            };
            
            selectedFournisseurs.forEach((fournisseur, index) => {
                const y = startY + 24 + (index * 12);
                const surcharge = 1 + (8 + Math.random() * 9) / 100; // 8-17% plus cher
                const concurrentCost = ohmCost * surcharge;
                
                // Couleur alternée
                if (index % 2 === 0) {
                    doc.setFillColor(249, 250, 251);
                    doc.rect(20, y, 170, 12, 'F');
                }
                
                // Logo coloré
                const color = fournisseurColors[fournisseur] || [100, 100, 100];
                doc.setFillColor(color[0], color[1], color[2]);
                doc.rect(22, y + 2, 15, 8, 'F');
                doc.setTextColor(255, 255, 255);
                doc.setFontSize(8);
                doc.text(fournisseur.substring(0, 4), 24, y + 7);
                
                doc.setTextColor(0, 0, 0);
                doc.setFontSize(10);
                doc.text(fournisseur, 40, y + 8);
                doc.text(`${Math.round(selectedAbonnement * surcharge)}€`, 70, y + 8);
                
                if (extractedData.segment === 'GAZ') {
                    doc.text(`${((prixOhmData.moyennes?.prix_molecule || 0) * surcharge).toFixed(2)} €/MWh`, 110, y + 8);
                } else if (extractedData.segment === 'C5-HPHC') {
                    doc.text(`HP:${((prixOhmData.moyennes?.prix_hp || 0) * surcharge).toFixed(1)}`, 110, y + 8);
                }
                
                doc.text(`${concurrentCost.toFixed(0)}€`, 150, y + 8);
            });
            
            // Recommandation stylée
            const recY = startY + 90;
            doc.setFillColor(16, 185, 129);
            doc.rect(20, recY, 170, 25, 'F');
            
            doc.setFontSize(14);
            doc.setTextColor(255, 255, 255);
            doc.setFont(undefined, 'bold');
            doc.text('🏆 RECOMMANDATION : OHM ÉNERGIE', 25, recY + 10);
            
            doc.setFontSize(10);
            doc.setFont(undefined, 'normal');
            doc.text('✓ Meilleur prix du marché  ✓ Prix fixe garanti 24 mois  ✓ Service client dédié', 25, recY + 20);
            
            // Pied de page
            doc.setFontSize(8);
            doc.setTextColor(0, 0, 0);
            doc.text(`Étude réalisée le ${new Date().toLocaleDateString('fr-FR')} | Contact : 09 84 32 74 25 | bo@ecogies.fr`, 20, 280);
            
            // Sauvegarde
            const fileName = `MEC_${extractedData.nom_client.replace(/[^a-zA-Z0-9]/g, '_')}_${new Date().toISOString().split('T')[0]}.pdf`;
            doc.save(fileName);
            
            alert('Document MEC professionnel généré avec succès !');
        }
        
        // Étape 7 - Email
        function generateEmailTemplate() {
            const currentCost = calculateCurrentCost();
            const ohmCost = calculateOhmCost();
            const savings = currentCost - ohmCost;
            const savingsPercent = currentCost > 0 ? ((Math.abs(savings) / currentCost) * 100).toFixed(1) : 0;
            
            // Préparer la salutation personnalisée
            const salutation = gerantData ? 
                `${gerantData.civilite} ${gerantData.gerantNom}` : 
                'Madame, Monsieur';
            
            let template = '';
            
            if (savings >= 0) {
                // Template pour économies positives
                template = `
                <div style="font-family: Arial, sans-serif; line-height: 1.6; color: #333;">
                    <h2 style="color: #00CED1;">Votre étude énergétique personnalisée</h2>
                    
                    <p>Bonjour ${salutation},</p>
                    
                    <p>Suite à l'analyse de votre facture d'énergie, nous avons le plaisir de vous présenter une <strong>opportunité d'économies significatives</strong> pour votre entreprise <strong>${extractedData.nom_client}</strong>.</p>
                    
                    <div style="background: #f0f9ff; border-left: 4px solid #00CED1; padding: 20px; margin: 20px 0;">
                        <h3 style="margin: 0; color: #1e3a8a;">💰 Résumé de vos économies</h3>
                        <ul style="margin: 10px 0;">
                            <li><strong>Économies annuelles :</strong> ${savings.toFixed(0)}€</li>
                            <li><strong>Pourcentage d'économie :</strong> ${savingsPercent}%</li>
                            <li><strong>Segment tarifaire :</strong> ${extractedData.segment}</li>
                            ${selectedEnergy !== 'gas' && extractedData.puissance_souscrite ? `<li><strong>Puissance souscrite :</strong> ${extractedData.puissance_souscrite} kVA</li>` : ''}
                        </ul>
                    </div>
                    
                    <h3>🔍 Notre analyse</h3>
                    <p>Votre contrat actuel chez <strong>${extractedData.fournisseur}</strong> arrive à échéance le <strong>${extractedData.date_fin_contrat}</strong>. C'est le moment idéal pour optimiser vos coûts énergétiques.</p>
                    
                    <h3>✅ Pourquoi choisir OHM Énergie ?</h3>
                    <ul>
                        <li><strong>Prix fixe garanti</strong> pendant toute la durée du contrat</li>
                        <li><strong>Aucune surprise</strong> sur vos factures</li>
                        <li><strong>Service client dédié</strong> aux professionnels</li>
                        <li><strong>Transition simplifiée</strong> - nous nous occupons de tout</li>
                    </ul>
                    
                    <div style="background: #10b981; color: white; padding: 20px; border-radius: 8px; text-align: center; margin: 20px 0;">
                        <h3 style="margin: 0;">🎯 Votre économie potentielle</h3>
                        <div style="font-size: 2em; font-weight: bold; margin: 10px 0;">${savings.toFixed(0)}€/an</div>
                        <p style="margin: 0;">soit ${savingsPercent}% d'économies sur votre facture actuelle</p>
                    </div>
                `;
            } else {
                // Template pour surcoût (économies négatives)
                template = `
                <div style="font-family: Arial, sans-serif; line-height: 1.6; color: #333;">
                    <h2 style="color: #00CED1;">Votre étude énergétique personnalisée</h2>
                    
                    <p>Bonjour ${salutation},</p>
                    
                    <p>Suite à l'analyse approfondie de votre facture d'énergie pour votre entreprise <strong>${extractedData.nom_client}</strong>, nous avons constaté que votre contrat actuel présente <strong>des conditions tarifaires déjà optimisées</strong>.</p>
                    
                    <div style="background: #fef2f2; border-left: 4px solid #ef4444; padding: 20px; margin: 20px 0;">
                        <h3 style="margin: 0; color: #dc2626;">📊 Résultat de l'analyse comparative</h3>
                        <ul style="margin: 10px 0;">
                            <li><strong>Différence tarifaire :</strong> +${Math.abs(savings).toFixed(0)}€/an</li>
                            <li><strong>Votre contrat actuel est ${savingsPercent}% moins cher</strong></li>
                            <li><strong>Segment tarifaire :</strong> ${extractedData.segment}</li>
                            ${selectedEnergy !== 'gas' && extractedData.puissance_souscrite ? `<li><strong>Puissance souscrite :</strong> ${extractedData.puissance_souscrite} kVA</li>` : ''}
                        </ul>
                    </div>
                    
                    <h3>🔍 Notre recommandation</h3>
                    <p>Votre contrat actuel chez <strong>${extractedData.fournisseur}</strong> qui arrive à échéance le <strong>${extractedData.date_fin_contrat}</strong> présente actuellement des conditions avantageuses par rapport au marché.</p>
                    
                    <p><strong>Nous vous recommandons de :</strong></p>
                    <ul>
                        <li>Conserver votre contrat actuel pour le moment</li>
                        <li>Rester vigilant sur l'évolution des prix du marché</li>
                        <li>Nous recontacter 3 mois avant votre prochaine échéance pour une nouvelle analyse</li>
                    </ul>
                    
                    <h3>✅ Comment OHM Énergie peut vous aider ?</h3>
                    <ul>
                        <li><strong>Veille tarifaire</strong> : Nous surveillons l'évolution des prix pour vous</li>
                        <li><strong>Alertes opportunités</strong> : Nous vous contactons dès qu'une économie devient possible</li>
                        <li><strong>Conseil personnalisé</strong> : Analyse gratuite à chaque renouvellement</li>
                        <li><strong>Optimisation énergétique</strong> : Conseils pour réduire votre consommation</li>
                    </ul>
                    
                    <div style="background: #fbbf24; color: #1e3a8a; padding: 20px; border-radius: 8px; text-align: center; margin: 20px 0;">
                        <h3 style="margin: 0;">💡 Conseil</h3>
                        <p style="margin: 10px 0; font-weight: bold;">Profitez de vos tarifs avantageux actuels</p>
                        <p style="margin: 0;">Nous restons à votre disposition pour toute future opportunité</p>
                    </div>
                `;
            }
            
            // Ajouter la signature commune
            template += `
                    <h3>📞 Restons en contact</h3>
                    <p>Je reste à votre disposition pour :</p>
                    <ul>
                        <li>Vous tenir informé de l'évolution du marché</li>
                        <li>Répondre à toutes vos questions énergétiques</li>
                        <li>Vous accompagner lors de votre prochaine échéance</li>
                    </ul>
                    
                    <p><strong>N'hésitez pas à me contacter :</strong></p>
                    <p>📧 Email : bo@ecogies.fr<br>
                    📞 Téléphone : 09 84 32 74 25</p>
                    
                    <p>Cordialement,<br><br>
                    <strong>L'équipe EcoGies</strong><br>
                    <em>Votre courtier en énergies</em></p>
                    
                    <hr style="margin: 30px 0; border: none; border-top: 1px solid #e5e7eb;">
                    <p style="font-size: 0.9em; color: #6b7280;">
                        EcoGies - Courtier en Énergies<br>
                        13 Bis rue George SAND, 94500 Champigny-Sur-Marne<br>
                        Tél: 09 84 32 74 25 | Email: bo@ecogies.fr
                    </p>
                </div>
            `;
            
            document.getElementById('emailTemplate').innerHTML = template;
        }
        
        function copyEmailTemplate() {
            const emailContent = document.getElementById('emailTemplate').innerText;
            navigator.clipboard.writeText(emailContent).then(() => {
                alert('Email copié dans le presse-papiers !');
            });
        }
        
        function resetWorkflow() {
            if (confirm('Êtes-vous sûr de vouloir recommencer une nouvelle analyse ?')) {
                // Reset toutes les variables
                selectedFiles = { file1: null, file2: null, file3: null };
                extractedData = null;
                currentStep = 1;
                selectedEnergy = 'electricity';
                selectedTariff = 'c5';
                selectedAbonnement = 240;
                selectedFournisseurs = [];
                volumeData = {};
                prixOhmData = {};
                validationStatus = { dataComplete: false, prixComplete: false };
                
                // Reset l'interface
                document.querySelectorAll('.step-content').forEach(content => content.classList.remove('active'));
                document.querySelectorAll('.step').forEach(step => {
                    step.classList.remove('active', 'completed');
                });
                
                document.getElementById('content1').classList.add('active');
                document.getElementById('step1').classList.add('active');
                
                // Reset les formulaires
                document.querySelectorAll('input[type="file"]').forEach(input => input.value = '');
                document.querySelectorAll('[id^="fileName"]').forEach(el => el.textContent = '');
                document.querySelectorAll('.energy-option, .abonnement-option, .fournisseur-card').forEach(el => el.classList.remove('selected'));
                
                alert('Interface réinitialisée pour une nouvelle analyse !');
            }
        }
        
        // Initialisation
        document.addEventListener('DOMContentLoaded', function() {
            // Sélectionner l'électricité par défaut
            document.querySelector('.energy-option').classList.add('selected');
            
            // Gestion de la fermeture du modal en cliquant en dehors
            window.onclick = function(event) {
                const modal = document.getElementById('rgpdModal');
                if (event.target === modal) {
                    closeRGPDModal();
                }
            }
        });
    </script>
</body>
</html>
