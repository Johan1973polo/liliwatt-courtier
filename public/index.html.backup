            <!-- Étape 4: Prix OHM avec moyennes -->
            <div class="step-content" id="content4">
                <h2 style="color: #1e3a8a; margin-bottom: 30px;">💰 Étape 4 : Prix OHM Énergie</h2>
                
                <div class="prix-section">
                    <div class="abonnement-choice">
